parameters:
    level: 9
    
    paths:
        - cli
        - config
        - modules
        - src
        
    excludePaths:
        analyse:
            - vendor
            - node_modules (?)
            - mobile_app (?)
            - update (?)
            - graphify-out (?)
            
    ignoreErrors:
        - '#Constant OWNPAY_INIT not found.#'
        
    reportUnmatchedIgnoredErrors: false
