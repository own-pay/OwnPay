parameters:
    level: 6
    paths:
        - src
    excludePaths:
        - vendor
        - mobile_app (?)
        - cli
        - update (?)
        - graphify-out (?)
        - node_modules (?)
    ignoreErrors:
        - '#Constant OWNPAY_INIT not found.#'
    reportUnmatchedIgnoredErrors: false
