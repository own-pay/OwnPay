{
    "name": "own-pay/ownpay",
    "description": "Own Pay v0.1.0 — Enterprise-grade Open-Source Payment Gateway",
    "type": "project",
    "license": "AGPL-3.0-or-later",
    "require": {
        "php": "^8.2",
        "ext-bcmath": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "ext-pdo": "*",
        "chillerlan/php-qrcode": "^5.0",
        "firebase/php-jwt": "^7.0",
        "ramsey/uuid": "^4.7",
        "twig/twig": "3.14.1",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "OwnPay\\": "src/"
        },
        "exclude-from-classmap": ["src/**/*Test.php"]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.5"
    },
    "scripts": {
        "security-check": "composer audit --format=json",
        "test": "vendor/bin/phpunit",
        "analyse": "vendor/bin/phpstan analyse"
    }
}
