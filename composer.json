{
    "name": "anirbanpay/anirbanpay",
    "description": "Anirban Pay — Enterprise-grade Open-Source Payment Gateway",
    "type": "project",
    "license": "AGPL-3.0-or-later",
    "require": {
        "php": "^8.2",
        "ext-bcmath": "*",
        "ext-json": "*",
        "ext-pdo": "*",
        "chillerlan/php-qrcode": "^5.0",
        "monolog/monolog": "^3.10",
        "ramsey/uuid": "^4.7",
        "vlucas/phpdotenv": "5.6",
        "xenon/nagad-api": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "AnirbanPay\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5"
    }
}
