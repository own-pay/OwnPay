      "https://*.bitpay.com"
    ],
    "style_src": [
      "https://*.bitpay.com"
    ],
    "frame_src": [
      "https://*.bitpay.com"
    ],
    "connect_src": [
      "https://*.bitpay.com",
      "https://bitpay.com",
      "https://test.bitpay.com"
    ]
  },
  "permissions": [
    "gateway.process",
    "gateway.refund"
  ],
  "icon": "icon.svg"
}
