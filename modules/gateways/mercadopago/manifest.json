{
  "name": "Mercado Pago",
  "slug": "mercadopago",
  "version": "1.0.0",
  "description": "Mercado Pago payment gateway integration for OwnPay",
  "author": "OwnPay Core",
  "type": "gateway",
  "entrypoint": "MercadoPagoGateway.php",
  "namespace": "OwnPay\\Modules\\Gateways\\MercadoPago",
  "capabilities": [
    "gateway"
  ],
  "requires": {
    "core": ">=0.1.0",
    "php": ">=8.1"
  },
  "category": "global",
  "color": "#00B1EA",
  "csp": {
    "script_src": [
      "https://*.mercadopago.com",
      "https://*.mercadolibre.com"
    ],
    "style_src": [
      "https://*.mercadopago.com"
    ],
    "frame_src": [
      "https://*.mercadopago.com"
    ],
    "connect_src": [
      "https://*.mercadopago.com",
      "https://api.mercadopago.com"
    ]
  },
  "permissions": [
    "gateway.process",
    "gateway.refund"
  ],
  "icon": "icon.svg"
}