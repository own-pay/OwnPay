{
  "name": "OpenNode",
  "slug": "opennode",
  "version": "1.0.0",
  "description": "OpenNode payment gateway integration for OwnPay",
  "author": "OwnPay Core",
  "type": "gateway",
  "entrypoint": "OpenNodeGateway.php",
  "namespace": "OwnPay\\Modules\\Gateways\\OpenNode",
  "capabilities": [
    "gateway"
  ],
  "requires": {
    "core": ">=0.1.0",
    "php": ">=8.1"
  },
  "category": "global",
  "color": "#1A1A1A",
  "csp": {
    "script_src": [
      "https://*.opennode.com"
    ],
    "style_src": [
      "https://*.opennode.com"
    ],
    "frame_src": [
      "https://*.opennode.com"
    ],
    "connect_src": [
      "https://*.opennode.com",
      "https://api.opennode.com",
      "https://dev-api.opennode.com"
    ]
  },
  "permissions": [
    "gateway.process"
  ],
  "icon": "icon.svg"
}