{
  "name": "KakaoPay",
  "slug": "kakaopay",
  "version": "1.0.0",
  "description": "KakaoPay payment gateway integration for OwnPay",
  "author": "OwnPay Core",
  "type": "gateway",
  "entrypoint": "KakaopayGateway.php",
  "namespace": "OwnPay\\Modules\\Gateways\\Kakaopay",
  "capabilities": [
    "gateway"
  ],
  "requires": {
    "core": ">=0.1.0",
    "php": ">=8.1"
  },
  "category": "global",
  "color": "#FFCD00",
  "csp": {
    "script_src": [
      "https://*.kakao.com",
      "https://*.kakaopay.com"
    ],
    "style_src": [
      "https://*.kakao.com"
    ],
    "frame_src": [
      "https://*.kakao.com"
    ],
    "connect_src": [
      "https://*.kakao.com",
      "https://kapi.kakao.com"
    ]
  },
  "permissions": [
    "gateway.process"
  ],
  "icon": "icon.svg"
}