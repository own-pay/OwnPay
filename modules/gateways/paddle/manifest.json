{
  "name": "Paddle",
  "slug": "paddle",
  "version": "1.0.0",
  "description": "Paddle payment gateway integration for OwnPay",
  "author": "OwnPay Core",
  "type": "gateway",
  "entrypoint": "PaddleGateway.php",
  "namespace": "OwnPay\\Modules\\Gateways\\Paddle",
  "capabilities": [
    "gateway",
    "http_outbound",
    "hooks"
  ],
  "requires": {
    "core": ">=0.1.0",
    "php": ">=8.2"
  },
  "category": "global",
  "color": "#00FF88",
  "csp": {
    "script_src": [
      "https://*.paddle.com",
      "https://checkout.paddle.com"
    ],
    "style_src": [
      "https://*.paddle.com",
      "https://checkout.paddle.com"
    ],
    "frame_src": [
      "https://*.paddle.com",
      "https://checkout.paddle.com"
    ],
    "connect_src": [
      "https://*.paddle.com",
      "https://checkout.paddle.com"
    ]
  },
  "permissions": [
    "gateway.process"
  ],
  "icon": "icon.svg"
}