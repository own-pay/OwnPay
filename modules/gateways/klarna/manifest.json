      "https://*.klarna.com"
    ],
    "connect_src": [
      "https://*.klarna.com",
      "https://api.klarna.com",
      "https://api.playground.klarna.com"
    ]
  },
  "permissions": [
    "gateway.process",
    "gateway.refund"
  ],
  "icon": "icon.svg"
}