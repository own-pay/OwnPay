{
  "name": "Upay",
  "slug": "upay",
  "version": "1.0.0",
  "description": "Upay payment gateway integration for OwnPay",
  "author": "OwnPay Core",
  "type": "gateway",
  "entrypoint": "UpayGateway.php",
