      "https://*.firstdata.com",
      "https://*.payeezy.com"
    ],
    "style_src": [
      "https://*.firstdata.com",
      "https://*.payeezy.com"
    ],
    "frame_src": [
      "https://*.firstdata.com",
      "https://*.payeezy.com"
    ],
    "connect_src": [
      "https://*.firstdata.com",
      "https://*.payeezy.com"
    ]
  },
