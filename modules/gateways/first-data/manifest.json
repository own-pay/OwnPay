{
  "name": "First Data",
  "slug": "first-data",
  "version": "1.0.0",
  "description": "First Data payment gateway integration for OwnPay",
  "author": "OwnPay Core",
  "type": "gateway",
  "entrypoint": "FirstDataGateway.php",
  "namespace": "OwnPay\\Modules\\Gateways\\FirstData",
  "capabilities": [
    "gateway",
    "http_outbound",
    "hooks"
  ],
  "requires": {
    "core": ">=0.1.0",
    "php": ">=8.2"
  },
  "category": "global",
  "color": "#004B87",
