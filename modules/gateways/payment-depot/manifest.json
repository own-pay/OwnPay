{
  "name": "Payment Depot",
  "slug": "payment-depot",
  "version": "1.0.0",
  "description": "Payment Depot payment gateway integration for OwnPay",
  "author": "OwnPay Core",
  "type": "gateway",
  "entrypoint": "PaymentDepotGateway.php",
  "namespace": "OwnPay\\Modules\\Gateways\\PaymentDepot",
  "capabilities": [
    "gateway",
    "http_outbound",
    "hooks"
  ],
  "requires": {
    "core": ">=0.1.0",
    "php": ">=8.2"
  },
  "category": "global",
  "color": "#059669",
  "csp": {
    "script_src": [
      "https://*.paymentdepot.com",
      "https://*.fattmerchant.com"
    ],
    "style_src": [
      "https://*.paymentdepot.com",
      "https://*.fattmerchant.com"
    ],
    "frame_src": [
      "https://*.paymentdepot.com",
      "https://*.fattmerchant.com"
    ],
    "connect_src": [
      "https://*.paymentdepot.com",
      "https://*.fattmerchant.com"
    ]
  },
  "permissions": [
    "gateway.process"
  ],
  "icon": "icon.svg"
}