<?xml version="1.0" encoding="UTF-8"?>
<!--
    Own Pay — IIS Web Configuration
    ================================
    Mirrors the protections in .htaccess (Apache) and nginx.conf.example (Nginx).

    What this file does:
      1. Enforces the front-controller pattern (all requests → index.php).
      2. Hides sensitive files (config, env, lock files, marker files).
      3. Hides internal directories (app/, src/, vendor/, tests/, errors/, migrations/, storage/).
      4. Explicitly blocks access to the installer directory (defense in depth).
      5. Disables directory browsing.
-->
<configuration>
    <system.webServer>

        <!-- 1. Front-controller URL rewriting -->
        <rewrite>
            <rules>

                <!-- Block sensitive top-level files -->
                <rule name="Block sensitive files" stopProcessing="true">
                    <match url="^(\.git|\.env|\.env\..+|op-config\.php|op-temp-config\.php|composer\.json|composer\.lock|README\.md|\.installed)$" ignoreCase="true" />
                    <action type="CustomResponse" statusCode="403" subStatusCode="0" statusReason="Forbidden" statusDescription="Forbidden" />
                </rule>

                <!-- Block orphaned test/debug scripts -->
                <rule name="Block test scripts" stopProcessing="true">
                    <match url="^(test_.*\.php|check_db\.php)$" ignoreCase="true" />
                    <action type="CustomResponse" statusCode="403" subStatusCode="0" statusReason="Forbidden" statusDescription="Forbidden" />
                </rule>

                <!-- Block internal source directories -->
                <rule name="Block internal directories" stopProcessing="true">
                    <match url="^(app|src|errors|tests|vendor|migrations|storage)/(.*)$" ignoreCase="true" />
                    <action type="CustomResponse" statusCode="403" subStatusCode="0" statusReason="Forbidden" statusDescription="Forbidden" />
                </rule>

                <!-- Explicit installer block (defense in depth) -->
                <rule name="Block installer directory" stopProcessing="true">
                    <match url="^app/install(/.*)?$" ignoreCase="true" />
                    <action type="CustomResponse" statusCode="403" subStatusCode="0" statusReason="Forbidden" statusDescription="Forbidden" />
                </rule>

                <!-- Front controller: route everything else to index.php -->
                <rule name="Front Controller" stopProcessing="true">
                    <match url=".*" />
                    <conditions logicalGrouping="MatchAll">
                        <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
                        <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
                    </conditions>
                    <action type="Rewrite" url="index.php?page={R:0}" appendQueryString="true" />
                </rule>

            </rules>
        </rewrite>

        <!-- 2. Defense-in-depth: deny via request filtering as well -->
        <security>
            <requestFiltering>
                <hiddenSegments>
                    <add segment="app" />
                    <add segment="src" />
                    <add segment="errors" />
                    <add segment="tests" />
                    <add segment="vendor" />
                    <add segment="migrations" />
                    <add segment="storage" />
                </hiddenSegments>
                <denyUrlSequences>
                    <add sequence=".env" />
                    <add sequence=".git" />
                    <add sequence=".installed" />
                </denyUrlSequences>
                <fileExtensions>
                    <add fileExtension=".sql"      allowed="false" />
                    <add fileExtension=".lock"     allowed="false" />
                    <add fileExtension=".md"       allowed="false" />
                    <add fileExtension=".env"      allowed="false" />
                    <add fileExtension=".installed" allowed="false" />
                </fileExtensions>
            </requestFiltering>
        </security>

        <!-- 3. Disable directory browsing -->
        <directoryBrowse enabled="false" />

        <!-- 4. Default document -->
        <defaultDocument>
            <files>
                <clear />
                <add value="index.php" />
                <add value="index.html" />
            </files>
        </defaultDocument>

    </system.webServer>
</configuration>
