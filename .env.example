# ────────────────────────────────────────────────────────
# Own Pay v0.1.0 — Environment Configuration
# ────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ────────────────────────────────────────────────────────

# ── Application ─────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=Asia/Dhaka
APP_URL=https://yourdomain.com
APP_KEY=                              # 32-char random key for encryption

# ── Database ────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ownpay
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ── Cache & Queue Driver ────────────────────────────────
# Options: 'file' (shared hosting) or 'redis' (VPS)
CACHE_DRIVER=file
QUEUE_DRIVER=file

# ── Redis (optional, only if CACHE_DRIVER=redis) ───────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PREFIX=op:

# ── JWT (Mobile API) ───────────────────────────────────
JWT_SECRET=                           # 64-char random key
JWT_TTL=3600                          # Token lifetime in seconds (1 hour)

# ── CORS ────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=*                # Comma-separated or * for all

# ── Mail (configured via Mail Gateway addon) ────────────
# MAIL_HOST=
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_FROM_ADDRESS=noreply@yourdomain.com
# MAIL_FROM_NAME="Own Pay"
