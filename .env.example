# ════════════════════════════════════════════════════════════════════════════════
# OwnPay v0.1.0 - Environment Configuration Template
# ════════════════════════════════════════════════════════════════════════════════
# Copy to .env and fill in your values.
# NEVER commit .env to version control.
# Run the web installer at /install to generate this automatically.
# ════════════════════════════════════════════════════════════════════════════════

# -- Application -----------------------------------------------------------------
APP_NAME="OwnPay"                     # Shown in admin panel, emails, receipts
APP_ENV=production                     # production | staging | development
APP_DEBUG=false                        # NEVER true in production
APP_URL=https://yourdomain.com         # Public-facing URL (no trailing slash)
APP_DOMAIN=yourdomain.com              # Master hostname (admin panel). Custom domains in op_domains resolve to brands.
APP_KEY=                               # 32-char random hex - run: openssl rand -hex 32
APP_TIMEZONE=Asia/Dhaka                # PHP timezone identifier

# If APP_URL is a local dev domain (e.g. https://ownpay.test) that external
# gateways (bKash, SSLCommerz, Stripe) cannot reach, set this to a public URL
# (e.g. an ngrok tunnel) so gateway callbacks/redirects work during development.
# Leave blank in production - APP_URL is used instead.
# GATEWAY_CALLBACK_URL=https://xxxx.ngrok-free.app

# -- Database --------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ownpay                         # Database name (letters, numbers, underscores only)
DB_USER=root
DB_PASS=
DB_PREFIX=op_                          # Table prefix (1-30 chars, [a-z0-9_])
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# -- Security --------------------------------------------------------------------
ENCRYPTION_KEY=                        # 64-char hex - run: openssl rand -hex 32
SESSION_LIFETIME=86400                 # Session TTL in seconds (default: 24h)
SESSION_SECURE=true                    # Set false only for local dev (HTTP)
BCRYPT_COST=12                         # Password hashing cost (10-14 recommended)
INSTALL_FORCE_KEY=                     # Leave empty. Only for deliberate reinstall over a populated DB:
                                       # set to 16+ random chars, send as X-Install-Force-Key header, remove after.

# -- JWT (Mobile API) ------------------------------------------------------------
JWT_SECRET=                            # 64-char random hex - run: openssl rand -hex 32
JWT_TTL=900                            # Access token lifetime in seconds (15 min)
JWT_REFRESH_TTL=7776000                # Refresh token lifetime in seconds (90 days)

# -- Cache & Queue ---------------------------------------------------------------
# Driver options: 'file' (shared hosting) | 'redis' (VPS/cloud)
CACHE_DRIVER=file
QUEUE_DRIVER=file
CACHE_TTL=3600                         # Default cache TTL in seconds

# -- Redis (only required if CACHE_DRIVER=redis or QUEUE_DRIVER=redis) ----------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=op:

# -- CORS ------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=                  # Comma-separated explicit origins, e.g. https://app.example.com,https://shop.example.com
                                       # Empty = no cross-origin access (safest). '*' allows all origins (credentials are
                                       # always denied in wildcard mode); only use for fully public, token-authenticated APIs.

# -- Trusted Proxies -------------------------------------------------------------
TRUSTED_PROXIES=                       # Comma-separated IPs of reverse proxies (Nginx, Cloudflare, etc.)
                                       # Example: 127.0.0.1,10.0.0.1,172.16.0.0/12
                                       # When set, X-Forwarded-For, X-Real-IP, X-Forwarded-Proto are trusted

# -- Rate Limiting ---------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=60              # Max API requests per minute per key
RATE_LIMIT_BURST=20                   # Burst allowance above per-minute limit

# -- Logging ---------------------------------------------------------------------
LOG_CHANNEL=file                       # file | stderr | syslog
LOG_LEVEL=error                        # debug | info | warning | error
LOG_MAX_FILES=7                        # Days of rotated log files to retain

# -- Error Tracking (optional) ---------------------------------------------------
# SENTRY_DSN=                          # Sentry DSN for production error tracking

# -- Mail (configured via Mail Gateway addon) ------------------------------------
# Leave commented if not using SMTP directly. Configure in Gateways → Mail addon.
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=noreply@yourdomain.com
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls                  # tls | ssl | none
# MAIL_FROM_ADDRESS=noreply@yourdomain.com
# MAIL_FROM_NAME="OwnPay"

# -- Telegram Notifications (via Telegram Bot addon) -----------------------------
# TELEGRAM_BOT_TOKEN=                  # From @BotFather
# TELEGRAM_CHAT_ID=                    # Your admin chat/group ID

# -- SMS Gateway (via SMS addon) -------------------------------------------------
# SMS_PROVIDER=                        # twilio | nexmo | custom
# SMS_API_KEY=
# SMS_API_SECRET=
# SMS_FROM=

# -- Developer / Debug -----------------------------------------------------------
# Only enable in development. NEVER in production.
# APP_DEBUG=true
# LOG_LEVEL=debug

# -- HMAC ------------------------------------------------------------------------
HMAC_KEY=                              # 64-char hex - run: openssl rand -hex 32
AUDIT_HMAC_SECRET=                     # 64-char hex - run: openssl rand -hex 32

# -- Update System ---------------------------------------------------------------
APP_VERSION=0.1.0                      # Current installed version
# UPDATE_CHECK_URL=                    # Override update manifest URL (default: https://update.ownpay.org/manifest.json)
