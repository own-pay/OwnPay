{
    "name": "Own Pay",
    "slug": "own-pay",
    "version": "1.0.0",
    "type": "theme",
    "description": "Native Own Pay checkout theme — Tailwind 3 + Outfit font, Cards/MFS/Bank tabs, manual-payment popup, configurable brand color.",
    "author": "Own Pay",
    "license": "AGPL-3.0",
    "min_php": "8.2",
    "min_app": "0.1.0",
    "entrypoint": "Theme.php",
    "namespace": "OwnPay",
    "capabilities": ["hooks", "settings", "checkout_ui"],
    "dependencies": [],
    "hooks": {
        "actions": ["admin.menu.register", "checkout.head_assets"],
        "filters": ["theme.checkout.render", "theme.invoice.render", "theme.payment_link.render"]
    },
    "admin_menu": [
        {
            "title": "Own Pay Theme",
            "slug": "own-pay-theme-settings",
            "icon": "palette",
            "parent": "settings",
            "permission": "manage_themes"
        }
    ],
    "cron": [],
    "migrations": []
}
