# =============================================================================
# Own Pay — Installer Directory: deny ALL direct web access
# =============================================================================
# This file is a defense-in-depth layer on top of the root .htaccess block on
# /app/, /src/, etc. The installer is loaded internally via the framework
# router (index.php?page=install) — it must NEVER be accessible directly.
# =============================================================================

# Apache 2.4+
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

# Apache 2.2
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>

# Disable directory indexing if the deny ever falters
Options -Indexes

# Refuse PHP execution as additional safety
<FilesMatch "\.(php|sql|md|json|env)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
