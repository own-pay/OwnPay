<div class="op-activity-details" style="padding: 5px;">
    <div style="margin-bottom: 20px; line-height: 1.6;">
        <p><strong>Action:</strong> <span class="op-badge op-badge-muted">{{ log.action }}</span></p>
        <p><strong>Performed By:</strong> {{ log.user_name }} (ID: {{ log.user_id ?? 'System' }})</p>
        <p><strong>Target Entity:</strong> {{ log.entity_type ?? 'N/A' }} {% if log.entity_id %}(ID: {{ log.entity_id }}){% endif %}</p>
        <p><strong>IP Address:</strong> {{ log.ip_address ?? 'N/A' }}</p>
        <p><strong>User Agent:</strong> <span class="op-text-sm op-text-muted">{{ log.user_agent ?? 'N/A' }}</span></p>
        <p><strong>Timestamp:</strong> {{ log.created_at ? log.created_at|date('Y-m-d H:i:s') : 'N/A' }}</p>
    </div>

    <div class="op-form-row">
        <div class="op-form-group op-col-6">
            <label style="font-weight: 600; display: block; margin-bottom: 8px;">Old Values (Before Change)</label>
            <pre class="op-code-block" style="background: var(--bg-hover, #f4f4f5); padding: 12px; border-radius: 6px; overflow-x: auto; font-family: monospace; font-size: 13px; max-height: 350px; border: 1px solid var(--border-color, #e4e4e7); color: var(--text-color, #09090b);">{{ old_values ? old_values|json_encode(constant('JSON_PRETTY_PRINT')) : '{}' }}</pre>
        </div>
        <div class="op-form-group op-col-6">
            <label style="font-weight: 600; display: block; margin-bottom: 8px;">New Values (After Change)</label>
            <pre class="op-code-block" style="background: var(--bg-hover, #f4f4f5); padding: 12px; border-radius: 6px; overflow-x: auto; font-family: monospace; font-size: 13px; max-height: 350px; border: 1px solid var(--border-color, #e4e4e7); color: var(--text-color, #09090b);">{{ new_values ? new_values|json_encode(constant('JSON_PRETTY_PRINT')) : '{}' }}</pre>
        </div>
    </div>
</div>
