{% extends 'admin/layout/base.twig' %}
{% block title %}Contributors - {{ app_name }}{% endblock %}

{% block head %}
<style nonce="{{ csp_nonce }}">
.op-contributor-name-link {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
}
.op-contributor-name-link:hover {
    color: var(--op-primary);
    text-decoration: underline;
}
</style>
{% endblock %}

{% block content %}
<div class="op-page-header">
    <div>
        <h1>Contributors</h1>
        <p class="op-page-subtitle">Credits and contributions for the open source developers of OwnPay.</p>
    </div>
    <a href="https://github.com/own-pay/OwnPay" target="_blank" rel="noopener" class="op-btn op-btn-outline">
        <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        View on GitHub
    </a>
</div>

<div class="op-contributors-grid" id="dynamic-contributors-grid">
    {% for contributor in contributors %}
    <div class="op-contributor-card">
        <div class="op-contributor-avatar">
            {% if contributor.avatar_url is defined and contributor.avatar_url %}
                <img src="{{ contributor.avatar_url }}" alt="{{ contributor.initials }}" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">
            {% else %}
                {{ contributor.initials }}
            {% endif %}
        </div>
        <div class="op-contributor-info">
            <div class="op-contributor-name">
                {% if contributor.github_url is defined and contributor.github_url %}
                    <a href="{{ contributor.github_url }}" target="_blank" rel="noopener" class="op-contributor-name-link">{{ contributor.name }}</a>
                {% else %}
                    {{ contributor.name }}
                {% endif %}
            </div>
            <div class="op-contributor-role">{{ contributor.role }}</div>
            <div class="op-contributor-commits">{{ contributor.commits }} commits</div>
        </div>
    </div>
    {% endfor %}
</div>
{% endblock %}

{% block scripts %}
<script nonce="{{ csp_nonce }}" src="/assets/js/pages/contributors.js?v=001"></script>
{% endblock %}
