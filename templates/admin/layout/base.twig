<!DOCTYPE html>
<html lang="{{ locale() }}" data-theme="dark" id="html-root">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ site_title ?? app_name }}{% endblock %}</title>
    <meta name="robots" content="noindex, nofollow">
    {% if site_favicon is defined and site_favicon %}
    <link rel="icon" href="{{ site_favicon }}" type="image/x-icon">
    {% endif %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/assets/css/admin.css?v=013">
    <meta name="csrf-token" content="{{ csrf_token }}">
    <script nonce="{{ csp_nonce }}" src="/assets/js/theme-init.js"></script>
    {% block head %}{% endblock %}
    {{ hook('admin.head')|raw }}
</head>
<body class="op-admin">
    <div class="op-layout">
        {% include 'admin/layout/sidebar.twig' %}

        <div class="op-main">
            {% include 'admin/layout/navbar.twig' %}

            <main class="op-content">
                {% if flash_success is defined and flash_success %}
                <div class="op-alert op-alert-success op-alert-dismissible">
                    {{ flash_success }}
                    <button type="button" class="op-alert-close">×</button>
                </div>
                {% endif %}
                {% if flash_error is defined and flash_error %}
                <div class="op-alert op-alert-danger op-alert-dismissible">
                    {{ flash_error }}
                    <button type="button" class="op-alert-close">×</button>
                </div>
                {% endif %}

                {% block content %}{% endblock %}
            </main>

            {% include 'admin/layout/footer.twig' %}
        </div>
    </div>

    {% include 'admin/layout/modals.twig' %}

    <script nonce="{{ csp_nonce }}" src="/assets/js/admin.js?v=013"></script>
    {% block scripts %}{% endblock %}
    {{ hook('admin.footer')|raw }}
</body>
</html>
