{% extends 'admin/layout/base.twig' %}
{% block title %}System Update — {{ app_name }}{% endblock %}
{% block content %}
<div class="op-page-header"><h1>System Update</h1></div>

<div class="op-grid op-grid-2">
    <div class="op-card">
        <div class="op-card-header"><h3>Current Version</h3></div>
        <div class="op-card-body">
            <div class="op-stat-card op-stat-primary op-mb-0">
                <div class="op-stat-content">
                    <span class="op-stat-value">v{{ current_version ?? '0.1.0' }}</span>
                    <span class="op-stat-label">Installed</span>
                </div>
            </div>
        </div>
    </div>

    <div class="op-card">
        <div class="op-card-header"><h3>Latest Available</h3></div>
        <div class="op-card-body">
            {% if update_available %}
            <div class="op-stat-card op-stat-success op-mb-2">
                <div class="op-stat-content">
                    <span class="op-stat-value">v{{ latest_version }}</span>
                    <span class="op-stat-label">Update Available!</span>
                </div>
            </div>
            <form method="POST" action="/admin/system-update/apply">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <input type="hidden" name="version" value="{{ latest_version }}">
                <button type="submit" class="op-btn op-btn-success op-btn-lg op-btn-block" onclick="return confirm('This will backup your system, apply the update, and run migrations. Continue?')">
                    Update to v{{ latest_version }}
                </button>
            </form>
            {% else %}
            <div class="op-stat-card op-stat-info op-mb-2">
                <div class="op-stat-content">
                    <span class="op-stat-value">v{{ current_version }}</span>
                    <span class="op-stat-label">Up to date ✓</span>
                </div>
            </div>
            <form method="POST" action="/admin/system-update/check">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <button type="submit" class="op-btn op-btn-outline">Check for Updates</button>
            </form>
            {% endif %}
        </div>
    </div>
</div>

<div class="op-card op-mt-4">
    <div class="op-card-header"><h3>Update History</h3></div>
    <div class="op-card-body op-p-0">
        <div class="op-table-responsive"><table class="op-table">
            <thead><tr><th>Version</th><th>Date</th><th>Status</th><th>Duration</th></tr></thead>
            <tbody>
                {% for entry in update_history %}
                <tr>
                    <td><code>v{{ entry.from_version }}</code> → <code>v{{ entry.to_version }}</code></td>
                    <td>{{ entry.started_at }}</td>
                    <td><span class="op-badge op-badge-{{ entry.status == 'completed' ? 'success' : (entry.status == 'failed' ? 'danger' : 'warning') }}">{{ entry.status }}</span></td>
                    <td>{{ entry.duration ?? '—' }}s</td>
                </tr>
                {% else %}
                <tr><td colspan="4" class="op-text-center">No update history.</td></tr>
                {% endfor %}
            </tbody>
        </table></div>
    </div>
</div>

<div class="op-card op-mt-4">
    <div class="op-card-header"><h3>Settings</h3></div>
    <div class="op-card-body">
        <form method="POST" action="/admin/system-update/settings" class="op-form">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <div class="op-form-group">
                <label class="op-checkbox-label"><input type="checkbox" name="auto_update" value="1" {{ auto_update ? 'checked' : '' }}>Enable Auto-Update (applies during 2-5 AM window)</label>
            </div>
            <button type="submit" class="op-btn op-btn-outline">Save</button>
        </form>
    </div>
</div>
{% endblock %}
