{% extends 'admin/layout/base.twig' %}
{% block title %}Domains — {{ app_name }}{% endblock %}
{% block content %}
<div class="op-page-header">
    <h1>Custom Domains</h1>
    <button class="op-btn op-btn-primary" onclick="document.getElementById('add-domain-form').hidden=!document.getElementById('add-domain-form').hidden">+ Add Domain</button>
</div>

<form method="POST" action="/admin/domains/add" class="op-card op-mb-4" id="add-domain-form" hidden>
    <div class="op-card-body">
        <input type="hidden" name="_csrf" value="{{ csrf_token }}">
        <div class="op-form-row">
            <div class="op-form-group op-col-8"><label>Domain</label><input type="text" name="domain" class="op-input" placeholder="pay.example.com" required></div>
            <div class="op-form-group op-col-4 op-flex op-items-end"><button type="submit" class="op-btn op-btn-primary">Add Domain</button></div>
        </div>
        <div class="op-alert op-alert-info op-mt-2">
            <strong>DNS Setup:</strong> Point your domain to <code>{{ server_ip ?? 'YOUR_SERVER_IP' }}</code> with an A record.
        </div>
    </div>
</form>

<div class="op-card">
    <div class="op-card-body op-p-0">
        <table class="op-table">
            <thead><tr><th>Domain</th><th>Merchant</th><th>DNS</th><th>SSL</th><th>Added</th><th>Actions</th></tr></thead>
            <tbody>
                {% for d in domains %}
                <tr>
                    <td><code>{{ d.domain }}</code></td>
                    <td>{{ d.merchant_name ?? '—' }}</td>
                    <td>
                        <span class="op-badge op-badge-{{ d.dns_verified ? 'success' : 'warning' }}">{{ d.dns_verified ? 'Verified' : 'Pending' }}</span>
                        {% if not d.dns_verified %}
                        <form method="POST" action="/admin/domains/{{ d.id }}/verify" class="op-inline op-ml-1">
                            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                            <button type="submit" class="op-btn op-btn-xs op-btn-outline">Re-check</button>
                        </form>
                        {% endif %}
                    </td>
                    <td><span class="op-badge op-badge-{{ d.ssl_active ? 'success' : 'muted' }}">{{ d.ssl_active ? 'Active' : 'N/A' }}</span></td>
                    <td>{{ d.created_at|date("M d, Y") }}</td>
                    <td>
                        <button onclick="openDeleteModal('/admin/domains/{{ d.id }}/delete','{{ d.domain }}')" class="op-btn op-btn-xs op-btn-danger">Remove</button>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
