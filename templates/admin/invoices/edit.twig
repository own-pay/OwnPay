{% extends 'admin/layout/base.twig' %}
{% block title %}{{ invoice.id ? 'Edit' : 'Create' }} Invoice — {{ app_name }}{% endblock %}
{% block content %}
<div class="op-page-header">
    <h1>{{ invoice.id ? 'Edit' : 'Create' }} Invoice</h1>
    <a href="/admin/invoices" class="op-btn op-btn-outline">← Back</a>
</div>
<form method="POST" action="/admin/invoices/{{ invoice.id ? invoice.id ~ '/edit' : 'create' }}" class="op-form">
    <input type="hidden" name="_csrf" value="{{ csrf_token }}">
    <div class="op-grid op-grid-2">
        <div class="op-card">
            <div class="op-card-header"><h3>Invoice Details</h3></div>
            <div class="op-card-body">
                <div class="op-form-group">
                    <label>Invoice Number</label>
                    <input type="text" name="invoice_number" value="{{ invoice.invoice_number ?? '' }}" class="op-input" required>
                </div>
                <div class="op-form-group">
                    <label>Customer</label>
                    <select name="customer_id" class="op-input">
                        <option value="">Select Customer</option>
                        {% for c in customers %}<option value="{{ c.id }}" {{ (invoice.customer_id ?? '') == c.id ? 'selected' : '' }}>{{ c.name }}</option>{% endfor %}
                    </select>
                </div>
                <div class="op-form-row">
                    <div class="op-form-group op-col-6">
                        <label>Currency</label>
                        <select name="currency" class="op-input">
                            {% for cur in currencies %}<option value="{{ cur.code }}" {{ (invoice.currency ?? 'BDT') == cur.code ? 'selected' : '' }}>{{ cur.code }}</option>{% endfor %}
                        </select>
                    </div>
                    <div class="op-form-group op-col-6">
                        <label>Due Date</label>
                        <input type="date" name="due_date" value="{{ invoice.due_date ?? '' }}" class="op-input" required>
                    </div>
                </div>
                <div class="op-form-group">
                    <label>Notes</label>
                    <textarea name="notes" rows="3" class="op-input">{{ invoice.notes ?? '' }}</textarea>
                </div>
            </div>
        </div>
        <div class="op-card">
            <div class="op-card-header"><h3>Line Items</h3><button type="button" id="add-item" class="op-btn op-btn-sm op-btn-outline">+ Add</button></div>
            <div class="op-card-body" id="items-container">
                {% set items = invoice.items ?? [{}] %}
                {% for i, item in items %}
                <div class="op-item-row op-form-row op-mb-2">
                    <div class="op-form-group op-col-5"><input type="text" name="items[{{ i }}][description]" value="{{ item.description ?? '' }}" class="op-input" placeholder="Description" required></div>
                    <div class="op-form-group op-col-2"><input type="number" name="items[{{ i }}][quantity]" value="{{ item.quantity ?? 1 }}" class="op-input" min="1" required></div>
                    <div class="op-form-group op-col-3"><input type="number" name="items[{{ i }}][amount]" value="{{ item.amount ?? '' }}" class="op-input" step="0.01" placeholder="Amount" required></div>
                    <div class="op-form-group op-col-2"><button type="button" class="op-btn op-btn-sm op-btn-danger remove-item">×</button></div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
    <div class="op-form-actions op-mt-4">
        <button type="submit" class="op-btn op-btn-primary op-btn-lg">{{ invoice.id ? 'Update' : 'Create' }} Invoice</button>
    </div>
</form>
<script>
let idx={{ items|length }};
document.getElementById('add-item').onclick=function(){
    const h='<div class="op-item-row op-form-row op-mb-2"><div class="op-form-group op-col-5"><input type="text" name="items['+idx+'][description]" class="op-input" placeholder="Description" required></div><div class="op-form-group op-col-2"><input type="number" name="items['+idx+'][quantity]" value="1" class="op-input" min="1" required></div><div class="op-form-group op-col-3"><input type="number" name="items['+idx+'][amount]" class="op-input" step="0.01" placeholder="Amount" required></div><div class="op-form-group op-col-2"><button type="button" class="op-btn op-btn-sm op-btn-danger remove-item">×</button></div></div>';
    idx++;document.getElementById('items-container').insertAdjacentHTML('beforeend',h);
};
document.getElementById('items-container').addEventListener('click',function(e){if(e.target.classList.contains('remove-item'))e.target.closest('.op-item-row').remove();});
</script>
{% endblock %}
