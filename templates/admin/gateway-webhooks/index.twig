{% extends 'admin/layout/base.twig' %}

{% block title %}Gateway Webhooks (IPN) — {{ app_name }}{% endblock %}

{% block content %}
<div class="op-page-header">
    <div>
        <h1>Gateway Webhooks (IPN)</h1>
        <p class="op-page-subtitle">The address your payment gateways use to tell {{ app_name }} when a payment happens. Copy it into your gateway dashboard.</p>
    </div>
</div>

{# ── What is it? (plain English) ─────────────────────────────── #}
<div class="op-card op-mb-4" style="padding:18px 20px;">
    <h2 class="op-card-title">What is a gateway webhook / IPN?</h2>
    <p class="op-text-sm" style="line-height:1.7;max-width:760px;">
        When a customer pays through a gateway (bKash, Nagad, Stripe, PayPal, and so on), the gateway needs a way
        to tell {{ app_name }} <em>“this payment succeeded / failed.”</em> It does that by quietly sending a message
        to a special web address on your site the moment the payment finishes. That address is called a
        <strong>webhook URL</strong> — some gateways call it <strong>IPN</strong> (Instant Payment Notification),
        <strong>callback URL</strong>, or <strong>notify URL</strong>. They all mean the same thing.
    </p>
    <p class="op-text-sm" style="line-height:1.7;max-width:760px;">
        You copy the URL below, paste it into your gateway’s dashboard once, and from then on payments update
        automatically — orders get marked paid, receipts go out, and your reports stay accurate without anyone
        clicking anything.
    </p>
</div>

{# ── Your webhook URL ────────────────────────────────────────── #}
<div class="op-card op-mb-4" style="padding:18px 20px;">
    <h2 class="op-card-title">Your webhook URL</h2>

    {% if is_global_view ?? true %}
        <p class="op-text-sm op-text-muted">
            You’re in <strong>All Brands</strong>. This uses your main {{ app_name }} address. Every brand can use
            this URL; to give a brand its own branded webhook address, switch to that brand and set a custom domain.
        </p>
    {% elseif using_brand_domain %}
        <p class="op-text-sm op-text-muted">
            Showing the webhook address for <strong>{{ brand_name ?? 'this brand' }}</strong> using its custom
            domain <strong>{{ brand_domain }}</strong>.
        </p>
    {% else %}
        <div class="op-card" style="padding:12px 16px;border:1px dashed var(--op-border,#d0d5dd);background:var(--op-surface-2,#f8fafc);margin-bottom:14px;">
            <span class="op-text-sm op-text-muted">
                <strong>{{ brand_name ?? 'This brand' }} has no custom domain yet.</strong>
                For a brand-specific webhook address, first add and verify a domain in
                <a href="/admin/domains">Domains</a>. Until then you can use the main {{ app_name }} webhook URL shown below
                (set from <strong>All Brands</strong>).
            </span>
        </div>
    {% endif %}

    {# Generic pattern #}
    <label class="op-text-xs op-text-muted" style="display:block;margin:6px 0 4px;">Base webhook address (replace the last part with your gateway’s name)</label>
    <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
        <input class="op-input" type="text" readonly value="{{ effective_base }}/{gateway}" style="flex:1 1 360px;font-family:monospace;">
        <button type="button" class="op-btn op-btn-sm op-btn-outline" data-copy="{{ effective_base }}/{gateway}">Copy</button>
    </div>

    {% if gateways is not empty %}
    <label class="op-text-xs op-text-muted" style="display:block;margin:16px 0 4px;">Ready-to-use URLs for your installed gateways</label>
    <div class="op-table-wrap">
        <table class="op-table">
            <thead><tr><th>Gateway</th><th>Webhook URL</th><th></th></tr></thead>
            <tbody>
            {% for gw in gateways %}
                <tr>
                    <td>{{ gw.name }}</td>
                    <td><code style="word-break:break-all;">{{ gw.url }}</code></td>
                    <td style="text-align:right;"><button type="button" class="op-btn op-btn-xs op-btn-outline" data-copy="{{ gw.url }}">Copy</button></td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
    {% endif %}
</div>

{# ── Setup guide ─────────────────────────────────────────────── #}
<div class="op-card op-mb-4" style="padding:18px 20px;">
    <h2 class="op-card-title">How to set it up</h2>
    <ol class="op-text-sm" style="line-height:1.8;max-width:760px;padding-left:18px;">
        <li>Copy the webhook URL for your gateway from the box above.</li>
        <li>Log in to that gateway’s own dashboard (for example bKash Merchant, Stripe Dashboard, PayPal).</li>
        <li>Find the setting named <strong>Webhook</strong>, <strong>IPN</strong>, <strong>Callback URL</strong>, or <strong>Notify URL</strong>. It’s usually under Developer, API, or Notifications settings.</li>
        <li>Paste the URL exactly as copied and save.</li>
        <li>If the gateway asks which events to send, choose payment success/completed and payment failed (or “all payment events”).</li>
        <li>Make a small test payment to confirm the status updates here automatically.</li>
    </ol>
</div>

{# ── Notes ───────────────────────────────────────────────────── #}
<div class="op-card" style="padding:18px 20px;">
    <h2 class="op-card-title">Good to know</h2>
    <ul class="op-text-sm op-text-muted" style="line-height:1.8;max-width:760px;padding-left:18px;">
        <li>Paste the address <strong>exactly</strong> — a missing or extra character means payments won’t update.</li>
        <li>The address must be reachable over the public internet on <strong>https</strong>. It won’t work on a laptop-only address.</li>
        <li>You don’t need to build or host anything — {{ app_name }} already listens at this address for you.</li>
        <li>Each brand can have its own address by giving the brand a custom domain in <a href="/admin/domains">Domains</a>; otherwise the main {{ app_name }} address (set from All Brands) is used.</li>
    </ul>
</div>
{% endblock %}
