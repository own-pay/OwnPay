{% extends 'admin/layout/base.twig' %}

{% block title %}Addons — {{ app_name }}{% endblock %}

{% block content %}
<div class="op-page-header">
    <div>
        <h1>Addons</h1>
        <p class="op-page-subtitle">Manage addon plugins, extra service integrations, and module configurations.</p>
    </div>
    {% if is_global_view ?? true %}
    <a href="/admin/plugins/install" class="op-btn op-btn-primary">
        <span class="op-icon">+</span> Install Addon
    </a>
    {% endif %}
</div>
{% if not (is_global_view ?? true) %}
{% include 'admin/partials/_all_brands_only.twig' with {title: 'Addons are managed from All Brands', message: 'Addons are uploaded once at the platform level, then activated per brand.'} only %}
{% endif %}



<div class="op-card">
    {% if addons|length > 0 %}
    <div class="op-addon-list">
        {% for addon in addons %}
        <div class="op-addon-item">
            <div class="op-addon-icon">
                {% if addon.logo_path is defined and addon.logo_path %}
                    <img src="{{ addon.logo_path }}" alt="{{ addon.name }}" width="48" height="48">
                {% else %}
                    <div class="op-addon-icon-placeholder">{{ addon.name|first|upper }}</div>
                {% endif %}
            </div>
            <div class="op-addon-info">
                <h4>{{ addon.name }}</h4>
                <p class="op-text-muted">{{ addon.description|default('No description') }}</p>
                <div class="op-addon-meta">
                    <span>v{{ addon.version }}</span>
                    <span class="op-dot"></span>
                    <span>{{ addon.author|default('Unknown') }}</span>
                    <span class="op-dot"></span>
                    {% if addon.status == 'active' %}
                        <span class="op-badge op-badge-success">Active</span>
                    {% else %}
                        <span class="op-badge op-badge-muted">Inactive</span>
                    {% endif %}
                </div>
            </div>
            <div class="op-addon-actions">
                {% if addon.status == 'active' %}
                    <a href="/admin/plugins/{{ addon.slug }}/settings" class="op-btn op-btn-sm op-btn-outline">Settings</a>
                    <form method="POST" action="/admin/plugins/{{ addon.slug }}/deactivate" class="op-inline-form">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                        <button type="submit" class="op-btn op-btn-sm op-btn-warning">Deactivate</button>
                    </form>
                {% else %}
                    <form method="POST" action="/admin/plugins/{{ addon.slug }}/activate" class="op-inline-form">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                        <button type="submit" class="op-btn op-btn-sm op-btn-success">Activate</button>
                    </form>
                {% endif %}
            </div>
        </div>
        {% endfor %}
    </div>
    {% else %}
        <p class="op-empty">No addons installed. <a href="/admin/plugins/install">Install one</a>.</p>
    {% endif %}
</div>
{% endblock %}
