{% extends 'admin/layout/base.twig' %}
{% block title %}Settings — {{ app_name }}{% endblock %}
{% block content %}
<div class="op-page-header"><h1>Settings</h1></div>

<div class="op-tabs">
    <button class="op-tab active" data-tab="general">General</button>
    <button class="op-tab" data-tab="payment">Payment</button>
    <button class="op-tab" data-tab="email">Email</button>
    <button class="op-tab" data-tab="api">API</button>
    <button class="op-tab" data-tab="security">Security</button>
    <button class="op-tab" data-tab="checkout">Checkout</button>
    <button class="op-tab" data-tab="notification">Notifications</button>
    <button class="op-tab" data-tab="theme">Theme</button>
    <button class="op-tab" data-tab="faq">FAQ</button>
    {{ hook('admin.settings.tabs')|raw }}
</div>

<form method="POST" action="/admin/settings/save" class="op-form">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

    {# ── General Tab ────────────────────────────────────────── #}
    <div class="op-tab-panel active" id="tab-general">
        <div class="op-card">
            <div class="op-card-header"><h3>Application Settings</h3></div>
            <div class="op-card-body">
                <div class="op-form-row">
                    <div class="op-form-group op-col-6">
                        <label>App Name *</label>
                        <input type="text" name="app_name" value="{{ settings.app_name ?? '' }}" class="op-input" required>
                        <small class="op-text-muted">Shown in header, emails, and receipts</small>
                    </div>
                    <div class="op-form-group op-col-6">
                        <label>Base URL</label>
                        <input type="url" name="base_url" value="{{ settings.base_url ?? '' }}" class="op-input" placeholder="https://pay.example.com">
                        <small class="op-text-muted">Public-facing URL of your payment gateway</small>
                    </div>
                </div>
                <div class="op-form-row">
                    <div class="op-form-group op-col-6">
                        <label>Timezone</label>
                        <select name="timezone" class="op-input">
                            {% for tz in timezones %}<option value="{{ tz }}" {{ (settings.timezone ?? 'Asia/Dhaka') == tz ? 'selected' : '' }}>{{ tz }}</option>{% endfor %}
                        </select>
                    </div>
                    <div class="op-form-group op-col-6">
                        <label>Support Email</label>
                        <input type="email" name="support_email" value="{{ settings.support_email ?? '' }}" class="op-input" placeholder="support@example.com">
                        <small class="op-text-muted">Shown on checkout and error pages</small>
                    </div>
                </div>
                <div class="op-form-group">
                    <label>Footer Text</label>
                    <input type="text" name="footer_text" value="{{ settings.footer_text ?? '' }}" class="op-input" placeholder="© 2026 Your Company. All rights reserved.">
                </div>
                <div class="op-form-group">
                    <label class="op-toggle-label">
                        <input type="checkbox" name="maintenance_mode" value="1" {{ (settings.maintenance_mode ?? 0)|raw ? 'checked' : '' }} id="maintenance-toggle">
                        <span class="op-toggle-switch"></span>
                        <span>Maintenance Mode</span>
                    </label>
                    <small class="op-text-muted op-text-warning" id="maintenance-warning" style="display:{{ (settings.maintenance_mode ?? 0)|raw ? 'block' : 'none' }}">
                        ⚠ Site is in maintenance mode. Public users see a 503 page. Admin panel stays accessible.
                    </small>
                </div>
            </div>
        </div>
        {{ hook('admin.settings.general')|raw }}
    </div>

    {# ── Payment Tab ────────────────────────────────────────── #}
    <div class="op-tab-panel" id="tab-payment">
        <div class="op-card">
            <div class="op-card-header"><h3>Payment Settings</h3></div>
            <div class="op-card-body">
                <div class="op-form-row">
                    <div class="op-form-group op-col-6">
                        <label>Default Currency</label>
                        <select name="default_currency" class="op-input">
                            {% for cur in currencies %}<option value="{{ cur.code }}" {{ (settings.default_currency ?? 'BDT') == cur.code ? 'selected' : '' }}>{{ cur.code }} — {{ cur.name }}</option>{% endfor %}
                        </select>
                    </div>
                    <div class="op-form-group op-col-6">
                        <label>Exchange Rate Update</label>
                        <select name="exchange_rate_mode" class="op-input">
                            <option value="auto" {{ (settings.exchange_rate_mode ?? 'auto') == 'auto' ? 'selected' : '' }}>Automatic</option>
                            <option value="manual" {{ (settings.exchange_rate_mode ?? '') == 'manual' ? 'selected' : '' }}>Manual</option>
                        </select>
                    </div>
                </div>
                <div class="op-form-row">
                    <div class="op-form-group op-col-6">
                        <label>Payment Expiry (minutes)</label>
                        <input type="number" name="payment_expiry_minutes" value="{{ settings.payment_expiry_minutes ?? 30 }}" class="op-input" min="5" max="1440">
                        <small class="op-text-muted">How long before unpaid checkout sessions expire</small>
                    </div>
                    <div class="op-form-group op-col-6">
                        <label>Invoice Due Days (default)</label>
                        <input type="number" name="invoice_due_days" value="{{ settings.invoice_due_days ?? 7 }}" class="op-input" min="1" max="365">
                    </div>
                </div>
                <div class="op-form-group">
                    <label class="op-toggle-label">
                        <input type="checkbox" name="auto_approve_payments" value="1" {{ (settings.auto_approve_payments ?? 0)|raw ? 'checked' : '' }}>
                        <span class="op-toggle-switch"></span>
                        <span>Auto-approve verified payments</span>
                    </label>
                    <small class="op-text-muted">When enabled, SMS-verified payments are approved automatically</small>
                </div>
            </div>
        </div>
        {{ hook('admin.settings.payment')|raw }}
    </div>

    {# ── Email Tab ──────────────────────────────────────────── #}
    <div class="op-tab-panel" id="tab-email">
        <div class="op-card">
            <div class="op-card-header"><h3>Email / SMTP Configuration</h3></div>
            <div class="op-card-body">
                <div class="op-form-row">
                    <div class="op-form-group op-col-8">
                        <label>SMTP Host</label>
                        <input type="text" name="smtp_host" value="{{ settings.smtp_host ?? '' }}" class="op-input" placeholder="smtp.gmail.com">
                    </div>
                    <div class="op-form-group op-col-4">
                        <label>SMTP Port</label>
                        <input type="number" name="smtp_port" value="{{ settings.smtp_port ?? 587 }}" class="op-input">
                    </div>
                </div>
                <div class="op-form-row">
                    <div class="op-form-group op-col-6">
                        <label>Encryption</label>
                        <select name="smtp_encryption" class="op-input">
                            <option value="tls" {{ (settings.smtp_encryption ?? 'tls') == 'tls' ? 'selected' : '' }}>TLS</option>
                            <option value="ssl" {{ (settings.smtp_encryption ?? '') == 'ssl' ? 'selected' : '' }}>SSL</option>
                            <option value="none" {{ (settings.smtp_encryption ?? '') == 'none' ? 'selected' : '' }}>None</option>
                        </select>
                    </div>
                    <div class="op-form-group op-col-6">
                        <label>SMTP Username</label>
                        <input type="text" name="smtp_username" value="{{ settings.smtp_username ?? '' }}" class="op-input">
                    </div>
                </div>
                <div class="op-form-group">
                    <label>SMTP Password</label>
                    <input type="password" name="smtp_password" value="{{ settings.smtp_password ?? '' }}" class="op-input" autocomplete="new-password">
                </div>
                <div class="op-form-row">
                    <div class="op-form-group op-col-6">
                        <label>From Email</label>
                        <input type="email" name="mail_from_email" value="{{ settings.mail_from_email ?? '' }}" class="op-input" placeholder="noreply@yourdomain.com">
                    </div>
                    <div class="op-form-group op-col-6">
                        <label>From Name</label>
                        <input type="text" name="mail_from_name" value="{{ settings.mail_from_name ?? '' }}" class="op-input" placeholder="Own Pay">
                    </div>
                </div>
            </div>
        </div>
        {{ hook('admin.settings.email')|raw }}
    </div>

    {# ── API Tab ────────────────────────────────────────────── #}
    <div class="op-tab-panel" id="tab-api">
        <div class="op-card">
            <div class="op-card-header"><h3>Webhook & Rate Limits</h3></div>
            <div class="op-card-body">
                <div class="op-form-group">
                    <label>Webhook URL</label>
                    <input type="url" name="webhook_url" value="{{ settings.webhook_url ?? '' }}" class="op-input" placeholder="https://yoursite.com/webhook">
                    <small class="op-text-muted">Receive payment event notifications at this URL</small>
                </div>
                <div class="op-form-group">
                    <label>API Rate Limit (requests/min)</label>
                    <input type="number" name="api_rate_limit" value="{{ settings.api_rate_limit ?? 60 }}" class="op-input" min="10" max="1000">
                </div>
            </div>
        </div>

        <div class="op-card op-mt-4">
            <div class="op-card-header"><h3>API Keys</h3></div>
            <div class="op-card-body">
                <table class="op-table">
                    <thead><tr><th>Label</th><th>Prefix</th><th>Created</th><th>Actions</th></tr></thead>
                    <tbody>
                        {% for key in api_keys %}
                        <tr>
                            <td>{{ key.name }}</td>
                            <td><code>{{ key.key_prefix }}****</code></td>
                            <td>{{ key.created_at|date('Y-m-d H:i') }}</td>
                            <td>
                                <button type="submit" form="revoke-form-{{ key.id }}" class="op-btn op-btn-sm op-btn-danger" onclick="return confirm('Revoke this key?')">Revoke</button>
                            </td>
                        </tr>
                        {% else %}
                        <tr><td colspan="4" class="op-text-center op-text-muted">No API keys found.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>

                <div class="op-mt-3 op-d-flex op-align-end">
                    <div class="op-form-group op-mr-2 op-mb-0">
                        <input type="text" name="label" form="generate-form" class="op-input op-input-sm" placeholder="New Key Label" required>
                    </div>
                    <button type="submit" form="generate-form" class="op-btn op-btn-sm op-btn-primary">Generate New Key</button>
                </div>
            </div>
        </div>
        {{ hook('admin.settings.api')|raw }}
    </div>

    {# ── Security Tab ───────────────────────────────────────── #}
    <div class="op-tab-panel" id="tab-security">
        <div class="op-card">
            <div class="op-card-header"><h3>Security Settings</h3></div>
            <div class="op-card-body">
                <div class="op-form-row">
                    <div class="op-form-group op-col-6">
                        <label>Session Timeout (minutes)</label>
                        <input type="number" name="session_timeout" value="{{ settings.session_timeout ?? 120 }}" class="op-input" min="5" max="1440">
                    </div>
                    <div class="op-form-group op-col-6">
                        <label>Max Login Attempts (per 5 min)</label>
                        <input type="number" name="max_login_attempts" value="{{ settings.max_login_attempts ?? 5 }}" class="op-input" min="1" max="20">
                    </div>
                </div>
                <div class="op-form-group">
                    <label>IP Allowlist</label>
                    <textarea name="ip_allowlist" rows="3" class="op-input" placeholder="One IP per line (leave empty = allow all)">{{ settings.ip_allowlist ?? '' }}</textarea>
                    <small class="op-text-muted">Leave empty to allow all IPs. One IP per line.</small>
                </div>
                <div class="op-form-group">
                    <label class="op-toggle-label">
                        <input type="checkbox" name="force_https" value="1" {{ (settings.force_https ?? 1)|raw ? 'checked' : '' }}>
                        <span class="op-toggle-switch"></span>
                        <span>Force HTTPS</span>
                    </label>
                </div>
                <div class="op-form-group">
                    <label class="op-toggle-label">
                        <input type="checkbox" name="require_2fa" value="1" {{ (settings.require_2fa ?? 0)|raw ? 'checked' : '' }}>
                        <span class="op-toggle-switch"></span>
                        <span>Require 2FA for all staff</span>
                    </label>
                </div>
            </div>
        </div>
        {{ hook('admin.settings.security')|raw }}
    </div>

    {# ── Checkout Tab ───────────────────────────────────────── #}
    <div class="op-tab-panel" id="tab-checkout">
        <div class="op-card">
            <div class="op-card-header"><h3>Checkout Page Settings</h3></div>
            <div class="op-card-body">
                <div class="op-form-group">
                    <label>Checkout Page Title</label>
                    <input type="text" name="checkout_title" value="{{ settings.checkout_title ?? 'Complete Payment' }}" class="op-input">
                </div>
                <div class="op-form-group">
                    <label>Success Message</label>
                    <textarea name="checkout_success_msg" rows="2" class="op-input">{{ settings.checkout_success_msg ?? 'Payment completed successfully! Thank you for your payment.' }}</textarea>
                </div>
                <div class="op-form-group">
                    <label>Pending Message</label>
                    <textarea name="checkout_pending_msg" rows="2" class="op-input">{{ settings.checkout_pending_msg ?? 'Your payment is being verified. You will receive a confirmation shortly.' }}</textarea>
                </div>
                <div class="op-form-group">
                    <label>Failed/Expired Message</label>
                    <textarea name="checkout_failed_msg" rows="2" class="op-input">{{ settings.checkout_failed_msg ?? 'This payment session has expired or was cancelled.' }}</textarea>
                </div>
                <div class="op-form-group">
                    <label>Terms & Conditions URL</label>
                    <input type="url" name="terms_url" value="{{ settings.terms_url ?? '' }}" class="op-input" placeholder="https://example.com/terms">
                </div>
                <div class="op-form-group">
                    <label>Privacy Policy URL</label>
                    <input type="url" name="privacy_url" value="{{ settings.privacy_url ?? '' }}" class="op-input" placeholder="https://example.com/privacy">
                </div>
            </div>
        </div>
        {{ hook('admin.settings.checkout')|raw }}
    </div>

    {# ── Notifications Tab ──────────────────────────────────── #}
    <div class="op-tab-panel" id="tab-notification">
        <div class="op-card">
            <div class="op-card-header"><h3>Notification Preferences</h3></div>
            <div class="op-card-body">
                <div class="op-form-group">
                    <label>Admin Notification Email</label>
                    <input type="email" name="admin_notification_email" value="{{ settings.admin_notification_email ?? '' }}" class="op-input" placeholder="admin@example.com">
                    <small class="op-text-muted">Receive payment notifications at this email</small>
                </div>
                <div class="op-form-group">
                    <label class="op-toggle-label">
                        <input type="checkbox" name="email_on_payment" value="1" {{ (settings.email_on_payment ?? 0)|raw ? 'checked' : '' }}>
                        <span class="op-toggle-switch"></span>
                        <span>Email on new payment</span>
                    </label>
                </div>
                <div class="op-form-group">
                    <label class="op-toggle-label">
                        <input type="checkbox" name="email_on_refund" value="1" {{ (settings.email_on_refund ?? 0)|raw ? 'checked' : '' }}>
                        <span class="op-toggle-switch"></span>
                        <span>Email on refund</span>
                    </label>
                </div>
            </div>
        </div>
        {{ hook('admin.settings.notification')|raw }}
    </div>

    {# ── Theme Tab ──────────────────────────────────────────── #}
    <div class="op-tab-panel" id="tab-theme">
        <div class="op-card">
            <div class="op-card-header"><h3>Theme Customization</h3></div>
            <div class="op-card-body">
                <div class="op-form-row">
                    <div class="op-form-group op-col-4">
                        <label>Primary Color</label>
                        <input type="color" name="theme_primary" value="{{ settings.theme_primary ?? '#6C5CE7' }}" class="op-input-color">
                    </div>
                    <div class="op-form-group op-col-4">
                        <label>Accent Color</label>
                        <input type="color" name="theme_accent" value="{{ settings.theme_accent ?? '#00CEC9' }}" class="op-input-color">
                    </div>
                    <div class="op-form-group op-col-4">
                        <label>Admin Theme</label>
                        <select name="theme_mode" class="op-input">
                            <option value="dark" {{ (settings.theme_mode ?? 'dark') == 'dark' ? 'selected' : '' }}>Dark</option>
                            <option value="light" {{ (settings.theme_mode ?? '') == 'light' ? 'selected' : '' }}>Light</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>
        {{ hook('admin.settings.theme')|raw }}
    </div>

    {# ── FAQ Tab ─────────────────────────────────────────────── #}
    <div class="op-tab-panel" id="tab-faq">
        <div class="op-card">
            <div class="op-card-header"><h3>Checkout FAQ</h3></div>
            <div class="op-card-body" id="faq-container">
                {% for i, faq in (settings.faqs ?? []) %}
                <div class="op-faq-row op-card op-card-bordered op-mb-2 op-p-3">
                    <div class="op-form-group"><label>Question</label><input type="text" name="faqs[{{ i }}][question]" value="{{ faq.question }}" class="op-input"></div>
                    <div class="op-form-group"><label>Answer</label><textarea name="faqs[{{ i }}][answer]" rows="2" class="op-input">{{ faq.answer }}</textarea></div>
                    <button type="button" class="op-btn op-btn-sm op-btn-danger" onclick="this.closest('.op-faq-row').remove()">Remove</button>
                </div>
                {% endfor %}
            </div>
            <div class="op-card-body op-p-3"><button type="button" class="op-btn op-btn-outline" id="add-faq">+ Add FAQ</button></div>
        </div>
        {{ hook('admin.settings.faq')|raw }}
    </div>

    <div class="op-form-actions op-mt-4"><button type="submit" class="op-btn op-btn-primary op-btn-lg">Save Settings</button></div>
</form>

<form id="generate-form" method="POST" action="/admin/api-keys/generate">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
</form>

{% for key in api_keys %}
<form id="revoke-form-{{ key.id }}" method="POST" action="/admin/api-keys/{{ key.id }}/revoke">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
</form>
{% endfor %}

<script>
// Tab switching
document.querySelectorAll('.op-tab').forEach(t=>t.addEventListener('click',function(){
    document.querySelectorAll('.op-tab,.op-tab-panel').forEach(e=>e.classList.remove('active'));
    this.classList.add('active');document.getElementById('tab-'+this.dataset.tab).classList.add('active');
    if (window.location.hash !== '#tab-' + this.dataset.tab) {
        history.replaceState(null, null, '#tab-' + this.dataset.tab);
    }
}));
// Hash-based tab activation
var targetTab = null;
if (window.location.hash) {
    targetTab = window.location.hash.replace('#tab-', '');
} else if ('{{ default_tab ?? "general" }}' !== 'general') {
    targetTab = '{{ default_tab ?? "general" }}';
}
if (targetTab) {
    const tab = document.querySelector('.op-tab[data-tab="' + targetTab + '"]');
    if (tab) tab.click();
}

// Maintenance mode warning toggle
const maintToggle = document.getElementById('maintenance-toggle');
const maintWarn = document.getElementById('maintenance-warning');
if (maintToggle && maintWarn) {
    maintToggle.addEventListener('change', function() {
        maintWarn.style.display = this.checked ? 'block' : 'none';
        if (this.checked && !confirm('Enable maintenance mode? Public users will see a 503 page.')) {
            this.checked = false;
            maintWarn.style.display = 'none';
        }
    });
}

// FAQ dynamic add
let faqIdx={{ (settings.faqs ?? [])|length }};
const addFaqBtn = document.getElementById('add-faq');
if (addFaqBtn) {
    addFaqBtn.onclick = function() {
        document.getElementById('faq-container').insertAdjacentHTML('beforeend','<div class="op-faq-row op-card op-card-bordered op-mb-2 op-p-3"><div class="op-form-group"><label>Question</label><input type="text" name="faqs['+faqIdx+'][question]" class="op-input"></div><div class="op-form-group"><label>Answer</label><textarea name="faqs['+faqIdx+'][answer]" rows="2" class="op-input"></textarea></div><button type="button" class="op-btn op-btn-sm op-btn-danger" onclick="this.closest(\'.op-faq-row\').remove()">Remove</button></div>');
        faqIdx++;
    };
}
</script>
{% endblock %}
