    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
</form>
{% endfor %}

<form id="cron-regenerate-form" method="POST" action="/admin/settings/cron/regenerate">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
</form>

{% for job in cron_jobs %}
<form id="cron-run-form-{{ job.name }}" method="POST" action="/admin/settings/cron/run/{{ job.name }}">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
</form>
{% endfor %}
    {% endif %}



<form id="logo-upload-form" method="POST" action="/admin/settings/upload" enctype="multipart/form-data" class="op-hidden">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
    <input type="file" name="site_logo" accept="image/*" id="logo-file-input" class="op-hidden">
</form>

<form id="favicon-upload-form" method="POST" action="/admin/settings/upload" enctype="multipart/form-data" class="op-hidden">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
    <input type="file" name="site_favicon" accept="image/*,.ico" id="favicon-file-input" class="op-hidden">
</form>

    {% if not is_brand_view %}
    <form id="currency-toggle-form" method="POST" action="" class="op-hidden">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
</form>

<form id="currency-sync-form" method="POST" action="/admin/currencies/sync-rates" class="op-hidden">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
</form>

<!-- Add Currency Modal -->
<div class="op-modal" id="add-currency-modal" hidden>
    <div class="op-modal-backdrop close-currency-modal-trigger"></div>
    <div class="op-modal-dialog">
        <div class="op-modal-header">
            <h3>Add New Currency</h3>
            <button type="button" class="op-modal-close close-currency-modal-trigger">&times;</button>
        </div>
        <form method="POST" action="/admin/currencies/update">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <div class="op-modal-body">
                <div class="op-form-group">
                    <label>Currency Code (ISO 4217) *</label>
                    <input type="text" name="code" class="op-input op-currency-code-input" required placeholder="e.g., USD" maxlength="3">
                </div>
                <div class="op-form-group">
                    <label>Name *</label>
                    <input type="text" name="name" class="op-input" required placeholder="e.g., US Dollar">
                </div>
                <div class="op-form-group">
                    <label>Symbol *</label>
                    <input type="text" name="symbol" class="op-input" required placeholder="e.g., $">
                </div>
                <div class="op-form-group">
                    <label>Decimal Places</label>
                    <input type="number" name="decimal_places" class="op-input" value="2" min="0" max="8">
                </div>
                <div class="op-form-group">
                    <label>Exchange Rate (relative to base currency)</label>
                    <input type="text" name="rate" class="op-input" placeholder="e.g., 1.0">
                </div>
                <div class="op-form-group">
                    <label>Status</label>
                    <select name="status" class="op-input">
                        <option value="active">Active</option>
                        <option value="inactive">Inactive</option>
                    </select>
                </div>
            </div>
            <div class="op-modal-footer">
                <button type="button" class="op-btn op-btn-outline close-currency-modal-trigger">Cancel</button>
                <button type="submit" class="op-btn op-btn-primary">Save Currency</button>
            </div>
        </form>
    </div>
</div>
{% endif %}

{% if is_brand_view %}
    {# -- Domain Action Forms -- #}
    {% for d in domains %}
        <form id="primary-domain-form-{{ d.id }}" method="POST" action="/admin/domains/{{ d.id }}/primary" style="display:none;">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
        </form>
        <form id="verify-domain-form-{{ d.id }}" method="POST" action="/admin/domains/{{ d.id }}/verify" style="display:none;">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
        </form>
        <form id="ssl-domain-form-{{ d.id }}" method="POST" action="/admin/domains/{{ d.id }}/check-ssl" style="display:none;">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
        </form>
        <form id="delete-domain-form-{{ d.id }}" method="POST" action="/admin/domains/{{ d.id }}/delete" style="display:none;">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
        </form>
    {% endfor %}

    <!-- Add Custom Domain Modal -->
    <div class="op-modal" id="add-domain-modal" hidden>
        <div class="op-modal-backdrop" data-close-modal="add-domain-modal"></div>
        <div class="op-modal-dialog">
            <div class="op-modal-header">
                <h3>Add Custom Domain</h3>
                <button class="op-modal-close" type="button" data-close-modal="add-domain-modal">×</button>
            </div>
            <form method="POST" action="/admin/domains">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <div class="op-modal-body">
                    <div class="op-form-group">
                        <label>Domain Name *</label>
                        <input type="text" name="domain" class="op-input op-input-lg" placeholder="pay.yourbusiness.com"
                               pattern="^([a-zA-Z0-9]([a-zA-Z0-9\-]{0,61}[a-zA-Z0-9])?\.)+[a-zA-Z]{2,}$"
                               title="Enter a valid domain name (e.g. pay.example.com)" required autofocus>
                        <small class="op-text-muted">Do not include <code>https://</code> - just the domain name</small>
                    </div>
                    <div class="op-form-group">
                        <label>Domain Type</label>
                        <select name="type" class="op-input">
                            <option value="checkout">Checkout domain</option>
                            <option value="admin">Admin domain</option>
                            <option value="api">API domain</option>
                        </select>
                    </div>
                    <div class="op-form-group">
                        <label>Redirect URL</label>
                        <input type="url" name="redirect_url" class="op-input" placeholder="https://example.com/failed-direct">
                        <small class="op-text-muted">Optional. Redirect target if accessed directly.</small>
                    </div>
                    <div class="op-alert op-alert-info">
                        After adding, you'll see the TXT verification token and server IP to configure in your DNS provider.
                    </div>
                </div>
                <div class="op-modal-footer">
                    <button type="button" class="op-btn op-btn-outline" data-close-modal="add-domain-modal">Cancel</button>
                    <button type="submit" class="op-btn op-btn-primary">Add Domain</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Edit Custom Domain Modal -->
    <div class="op-modal" id="edit-domain-modal" hidden>
        <div class="op-modal-backdrop" data-close-modal="edit-domain-modal"></div>
        <div class="op-modal-dialog">
            <div class="op-modal-header">
                <h3>Edit Custom Domain Settings</h3>
                <button class="op-modal-close" type="button" data-close-modal="edit-domain-modal">×</button>
            </div>
            <form method="POST" action="">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <div class="op-modal-body">
                    <div class="op-form-group">
                        <label>Domain Name</label>
                        <input type="text" name="domain_display" class="op-input" disabled>
                    </div>
                    <div class="op-form-group">
                        <label>Domain Type</label>
                        <select name="type" class="op-input">
                            <option value="checkout">Checkout domain</option>
                            <option value="admin">Admin domain</option>
                            <option value="api">API domain</option>
                        </select>
                    </div>
                    <div class="op-form-group">
                        <label>Redirect URL</label>
                        <input type="url" name="redirect_url" class="op-input" placeholder="https://example.com/failed-direct">
                        <small class="op-text-muted">Optional. Redirect target if accessed directly.</small>
                    </div>
                    <div class="op-form-group">
                        <label>Domain Status</label>
                        <select name="status" class="op-input">
                            <option value="active">Active</option>
                            <option value="pending">Pending DNS</option>
                            <option value="inactive">Inactive</option>
                        </select>
                    </div>
                    <div class="op-form-group">
                        <label>DNS Verification State</label>
                        <select name="dns_verified" class="op-input">
                            <option value="1">Verified (1)</option>
                            <option value="0">Unverified / Pending (0)</option>
                        </select>
                    </div>
                    <div class="op-form-group">
                        <label>Is Primary Domain</label>
                        <select name="is_primary" class="op-input">
                            <option value="1">Yes (Primary)</option>
                            <option value="0">No (Secondary)</option>
                        </select>
                    </div>
                </div>
                <div class="op-modal-footer">
                    <button type="button" class="op-btn op-btn-outline" data-close-modal="edit-domain-modal">Cancel</button>
                    <button type="submit" class="op-btn op-btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
{% endif %}

{% endblock %}
{% block scripts %}
<script nonce="{{ csp_nonce }}" src="/assets/js/pages/settings.js"></script>
{% endblock %}

