    {# ── Cron Jobs Tab ────────────────────────────────────── #}
    <div class="op-tab-panel {{ default_tab == 'cron' ? 'active' : '' }}" id="tab-cron">
        <div class="op-alert op-alert-info op-mb-4">
            <div style="display: flex; align-items: flex-start; gap: 12px;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink: 0; margin-top: 2px;">
                    <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                </svg>
                <div>
                    <strong style="display: block; margin-bottom: 4px;">Cron Service Configured</strong>
                    <span>Scheduled tasks automate queue processing, transaction matching, SMS notifications, and system audits. Set up the crontab entry below on your server to run every minute.</span>
                </div>
            </div>
        </div>

        <div class="op-card op-mb-4">
            <div class="op-card-header">
                <h3 style="margin: 0; display: flex; align-items: center; gap: 8px;">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    Cron Credentials & Command
                </h3>
            </div>
            <div class="op-card-body">
                <div class="op-form-group op-mb-4">
                    <label>Cron Trigger Secret</label>
                    <div style="position: relative; display: flex; align-items: center; background: var(--op-bg-input); border: 1px solid var(--op-border); border-radius: var(--op-radius); overflow: hidden;">
                        <input type="password" id="cron-secret-input" value="{{ cron_secret }}" class="op-input" readonly style="border: none; background: transparent; padding: 12px 110px 12px 14px; font-family: monospace; width: 100%; color: var(--op-text);">
                        <div style="position: absolute; right: 8px; display: flex; gap: 6px;">
                            <button type="button" class="op-btn op-btn-sm op-btn-outline" onclick="toggleCronSecret()" title="Toggle visibility" style="height: 32px; width: 36px; padding: 0; display: inline-flex; align-items: center; justify-content: center; border-radius: 4px; border: 1px solid var(--op-border); background: var(--op-bg-card);">
                                <svg id="secret-eye-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            </button>
                            <button type="button" class="op-btn op-btn-sm op-btn-outline" onclick="copyToClipboard('#cron-secret-input', this)" title="Copy Secret" style="height: 32px; width: 36px; padding: 0; display: inline-flex; align-items: center; justify-content: center; border-radius: 4px; border: 1px solid var(--op-border); background: var(--op-bg-card);">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                            </button>
                        </div>
                    </div>
                    <small class="op-text-muted" style="margin-top: 6px; display: block;">Used to authenticate public cron requests securely. Keep this secret private.</small>
                    <div class="op-mt-3">
                        <button type="submit" form="cron-regenerate-form" class="op-btn op-btn-sm op-btn-danger" onclick="return confirm('WARNING: Regenerating the secret will invalidate your current crontab setup. Continue?')">
                            🔄 Regenerate Secret
                        </button>
                    </div>
                </div>

                <hr style="border: none; border-top: 1px solid var(--op-border); margin: 20px 0;">

                <div class="op-form-group op-mb-4">
                    <label>Webhook Execution URL</label>
                    <div style="position: relative; display: flex; align-items: center; background: var(--op-bg-input); border: 1px solid var(--op-border); border-radius: var(--op-radius); overflow: hidden;">
                        <input type="text" id="cron-url-input" value="{{ cron_url }}" class="op-input" readonly style="border: none; background: transparent; padding: 12px 60px 12px 14px; font-family: monospace; width: 100%; color: var(--op-primary);">
                        <div style="position: absolute; right: 8px;">
                            <button type="button" class="op-btn op-btn-sm op-btn-outline" onclick="copyToClipboard('#cron-url-input', this)" title="Copy URL" style="height: 32px; width: 36px; padding: 0; display: inline-flex; align-items: center; justify-content: center; border-radius: 4px; border: 1px solid var(--op-border); background: var(--op-bg-card);">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                            </button>
                        </div>
                    </div>
                    <small class="op-text-muted" style="margin-top: 6px; display: block;">Configure external web cron services (e.g., EasyCron) to send requests here.</small>
                </div>

                <hr style="border: none; border-top: 1px solid var(--op-border); margin: 20px 0;">

                <div class="op-form-group">
                    <label>Recommended Crontab Command</label>
                    <div style="position: relative; display: flex; align-items: center; background: var(--op-bg-input); border: 1px solid var(--op-border); border-radius: var(--op-radius); overflow: hidden;">
                        <input type="text" id="cron-cmd-input" value="* * * * * curl -s -S &quot;{{ cron_url }}&quot; > /dev/null 2>&1" class="op-input" readonly style="border: none; background: transparent; padding: 12px 60px 12px 14px; font-family: monospace; width: 100%; color: var(--op-text); font-size: 0.85rem;">
                        <div style="position: absolute; right: 8px;">
                            <button type="button" class="op-btn op-btn-sm op-btn-outline" onclick="copyToClipboard('#cron-cmd-input', this)" title="Copy Command" style="height: 32px; width: 36px; padding: 0; display: inline-flex; align-items: center; justify-content: center; border-radius: 4px; border: 1px solid var(--op-border); background: var(--op-bg-card);">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                            </button>
                        </div>
                    </div>
                    <small class="op-text-muted" style="margin-top: 6px; display: block;">SSH to your server, type <code>crontab -e</code>, and add the line above to trigger scheduled tasks every minute.</small>
                </div>
            </div>
        </div>

        <div class="op-card">
            <div class="op-card-header">
                <h3 style="margin: 0; display: flex; align-items: center; gap: 8px;">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                    Registered System Cron Jobs
                </h3>
            </div>
            <div class="op-card-body" style="padding: 0;">
                <table class="op-table">
                    <thead>
                        <tr>
                            <th>Job Name & Description</th>
                            <th>Schedule Interval</th>
                            <th>Last Run Status</th>
                            <th style="text-align: right;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for job in cron_jobs %}
                        <tr>
                            <td>
                                <div style="font-weight: 600; font-size: 0.95rem; color: var(--op-text);">{{ job.name }}</div>
                                <div style="font-size: 0.8rem; color: var(--op-text-muted); margin-top: 4px; line-height: 1.4;">{{ job.description }}</div>
                            </td>
                            <td>
                                <span class="op-badge op-badge-info" style="display: inline-flex; align-items: center; gap: 4px; padding: 4px 10px; border-radius: 12px; font-weight: 500;">
                                    ⏱ {{ job.schedule }}
                                </span>
                            </td>
                            <td>
                                {% if job.last_run == 'Never' %}
                                <span class="op-badge op-badge-warning" style="display: inline-flex; align-items: center; gap: 6px; padding: 4px 10px; border-radius: 12px; font-weight: 500;">
                                    <span class="op-status-dot" style="width: 6px; height: 6px; border-radius: 50%; display: inline-block; background: var(--op-warning);"></span>
                                    Never Executed
                                </span>
                                {% else %}
                                <span class="op-badge op-badge-success" style="display: inline-flex; align-items: center; gap: 6px; padding: 4px 10px; border-radius: 12px; font-weight: 500;" title="Last execution timestamp: {{ job.last_run_timestamp|date('Y-m-d H:i:s') }}">
                                    <span class="op-status-dot" style="width: 6px; height: 6px; border-radius: 50%; display: inline-block; background: var(--op-success); box-shadow: 0 0 6px var(--op-success);"></span>
                                    {{ job.last_run }}
                                </span>
                                {% endif %}
                            </td>
                            <td style="text-align: right;">
                                <button type="submit" form="cron-run-form-{{ job.name }}" class="op-btn op-btn-sm op-btn-primary" style="display: inline-flex; align-items: center; gap: 6px;">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                                    Run Now
                                </button>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="4" class="op-text-center op-text-muted" style="padding: 30px; font-style: italic;">No scheduled jobs registered.</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        {{ hook('admin.settings.cron')|raw }}
    </div>

    <div class="op-form-actions op-mt-4"><button type="submit" class="op-btn op-btn-primary op-btn-lg">Save Settings</button></div>
</form>

