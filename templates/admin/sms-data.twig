{% extends 'admin/layout/base.twig' %}
{% block title %}SMS Data — {{ app_name }}{% endblock %}
{% block content %}
<div class="op-page-header"><h1>SMS Data</h1></div>
<div class="op-card">
    <div class="op-card-header">
        <h3>Parsed SMS</h3>
        <form method="GET" class="op-filter-bar">
            <select name="status" class="op-input op-input-sm">
                <option value="">All</option>
                <option value="matched" {{ (filters.status ?? '') == 'matched' ? 'selected' : '' }}>Matched</option>
                <option value="unmatched" {{ (filters.status ?? '') == 'unmatched' ? 'selected' : '' }}>Unmatched</option>
                <option value="pending" {{ (filters.status ?? '') == 'pending' ? 'selected' : '' }}>Pending</option>
            </select>
            <button type="submit" class="op-btn op-btn-sm op-btn-primary">Filter</button>
        </form>
    </div>
    <div class="op-card-body op-p-0">
        <div class="op-table-responsive"><table class="op-table">
            <thead><tr><th>Sender</th><th>Amount</th><th>TRX ID</th><th>Gateway</th><th>Status</th><th>Received</th></tr></thead>
            <tbody>
                {% for sms in sms_data %}
                <tr>
                    <td>{{ sms.sender }}</td>
                    <td>{{ sms.amount ?? '—' }}</td>
                    <td><code>{{ sms.trx_id ?? '—' }}</code></td>
                    <td>{{ sms.gateway_slug ?? '—' }}</td>
                    <td><span class="op-badge op-badge-{{ sms.match_status == 'matched' ? 'success' : (sms.match_status == 'pending' ? 'warning' : 'muted') }}">{{ sms.match_status ?? '—' }}</span></td>
                    <td>{{ sms.received_at is defined and sms.received_at ? sms.received_at|date("M d, H:i") : '—' }}</td>
                </tr>
                {% else %}
                <tr><td colspan="6" class="op-text-center op-text-muted">No parsed SMS data found.</td></tr>
                {% endfor %}
            </tbody>
        </table></div>
    </div>
</div>
{% if pagination.total_pages > 1 %}
<nav class="op-pagination">
    {% if pagination.has_prev %}<a href="?page={{ pagination.page - 1 }}&status={{ filters.status ?? '' }}" class="op-page-link">← Prev</a>{% endif %}
    <span class="op-page-info">Page {{ pagination.page }} of {{ pagination.total_pages }}</span>
    {% if pagination.has_next %}<a href="?page={{ pagination.page + 1 }}&status={{ filters.status ?? '' }}" class="op-page-link">Next →</a>{% endif %}
</nav>
{% endif %}
{% endblock %}
