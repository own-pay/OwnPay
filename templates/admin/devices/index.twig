{% extends 'admin/layout/base.twig' %}
{% block title %}Paired Devices — {{ app_name }}{% endblock %}
{% block content %}
<div class="op-page-header">
    <div>
        <h1>📱 Paired Devices</h1>
        <p class="op-text-muted op-mt-1">Manage mobile companion app connections for this brand.</p>
    </div>
    <button class="op-btn op-btn-primary" id="pair-device-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px;margin-right:6px"><path d="M12 5v14M5 12h14"/></svg>Pair New Device
    </button>
</div>

{% if config_error is defined and config_error %}
<div class="op-alert op-alert-warning op-mb-4">
    <strong>⚠ Configuration Required:</strong> {{ config_error }}
</div>
{% endif %}

{# ── Stats Cards ─────────────────────────────────────────── #}
{% if stats is defined %}
<div class="op-stats-grid op-mb-4">
    <div class="op-stat-card">
        <div class="op-stat-icon" style="background:linear-gradient(135deg,#6366f1,#8b5cf6)">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12" y2="18.01"/></svg>
        </div>
        <div class="op-stat-content">
            <span class="op-stat-value">{{ stats.total }}</span>
            <span class="op-stat-label">Total Devices</span>
        </div>
    </div>
    <div class="op-stat-card op-stat-success">
        <div class="op-stat-icon" style="background:linear-gradient(135deg,#22c55e,#16a34a)">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <div class="op-stat-content">
            <span class="op-stat-value">{{ stats.active }}</span>
            <span class="op-stat-label">Active</span>
        </div>
    </div>
    <div class="op-stat-card">
        <div class="op-stat-icon" style="background:linear-gradient(135deg,#ef4444,#dc2626)">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        </div>
        <div class="op-stat-content">
            <span class="op-stat-value">{{ stats.revoked }}</span>
            <span class="op-stat-label">Revoked</span>
        </div>
    </div>
</div>
{% endif %}

{# ── Pairing Panel ───────────────────────────────────────── #}
<div class="op-card op-mb-4 op-pairing-panel" id="pairing-panel" style="display:none">
    <div class="op-card-header">
        <h3>🔗 Pair Mobile Device</h3>
        <button class="op-btn op-btn-xs op-btn-ghost" onclick="document.getElementById('pairing-panel').style.display='none'">✕ Close</button>
    </div>
    <div class="op-card-body">
        <div class="op-form-row op-align-start">
            <div class="op-col-6">
                <div class="op-pairing-step">
                    <span class="op-step-number">1</span>
                    <h4>Generate Pairing Code</h4>
                </div>
                <p class="op-text-muted op-mb-3">Click below to generate a one-time 6-digit pairing code. Valid for 5 minutes.</p>
                <button class="op-btn op-btn-primary op-btn-lg" id="gen-otp-btn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-3px;margin-right:6px"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>Generate Pairing Code
                </button>

                <div id="otp-display" style="display:none" class="op-mt-4">
                    <div class="op-otp-container">
                        <div class="op-otp-code" id="otp-value">——————</div>
                        <div class="op-otp-timer">Expires in <span id="otp-timer">5:00</span></div>
                    </div>
                </div>
            </div>
            <div class="op-col-6">
                <div class="op-pairing-step">
                    <span class="op-step-number">2</span>
                    <h4>Enter in Mobile App</h4>
                </div>
                <ol class="op-steps-list">
                    <li>Open <strong>OwnPay</strong> companion app on phone</li>
                    <li>Tap <strong>"Pair with Admin"</strong></li>
                    <li>Enter the 6-digit code shown on the left</li>
                    <li>Phone confirms — device appears below</li>
                </ol>
                <div class="op-alert op-alert-info op-mt-3">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px;margin-right:4px"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    <strong>Security:</strong> Code is single-use and expires in 5 minutes. Device fingerprint is verified on pairing.
                </div>
            </div>
        </div>
    </div>
</div>

{# ── Device List ─────────────────────────────────────────── #}
<div class="op-card">
    <div class="op-card-header">
        <h3>Connected Devices</h3>
        {% if devices|length > 0 %}
        <form method="POST" action="/admin/devices/bulk-revoke" id="bulk-revoke-form">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <button type="submit" class="op-btn op-btn-sm op-btn-danger"
                    onclick="return confirm('Revoke ALL selected devices?')"
                    id="bulk-revoke-btn" disabled>
                Revoke Selected
            </button>
        </form>
        {% endif %}
    </div>
    <div class="op-card-body op-p-0">
        <table class="op-table">
            <thead>
                <tr>
                    {% if devices|length > 0 %}<th width="40"><input type="checkbox" id="select-all"></th>{% endif %}
                    <th>Device</th>
                    <th>Platform</th>
                    <th>Status</th>
                    <th>Last Seen</th>
                    <th>Paired</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for d in devices %}
                <tr>
                    <td><input type="checkbox" class="device-checkbox" name="device_ids[]" value="{{ d.device_id }}" form="bulk-revoke-form"></td>
                    <td>
                        <div class="op-device-info">
                            <div class="op-device-icon">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12" y2="18.01"/></svg>
                            </div>
                            <div>
                                <strong>{{ d.device_name ?? 'Unknown Device' }}</strong>
                                <div class="op-text-xs op-text-muted"><code>{{ d.device_id|slice(0,8) }}…</code></div>
                            </div>
                        </div>
                    </td>
                    <td><span class="op-text-muted">{{ d.platform ?? '—' }}</span></td>
                    <td>
                        <span class="op-badge op-badge-{{ d.status == 'active' ? 'success' : (d.status == 'revoked' ? 'danger' : 'muted') }}">
                            <span class="op-status-dot"></span>{{ d.status|capitalize }}
                        </span>
                    </td>
                    <td class="op-text-muted">{{ d.last_heartbeat ?? 'Never' }}</td>
                    <td class="op-text-muted">{{ d.paired_at ? d.paired_at|date('M d, Y') : '—' }}</td>
                    <td>
                        {% if d.status == 'active' %}
                        <form method="POST" action="/admin/devices/{{ d.device_id }}/revoke" class="op-inline-form"
                              onsubmit="return confirm('Revoke {{ d.device_name ?? d.device_id }}?')">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                            <button type="submit" class="op-btn op-btn-sm op-btn-danger">Revoke</button>
                        </form>
                        {% else %}
                        <span class="op-text-muted op-text-xs">—</span>
                        {% endif %}
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="7" class="op-empty-state">
                        <div class="op-empty-icon">
                            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12" y2="18.01"/></svg>
                        </div>
                        <p class="op-empty-title">No devices paired yet</p>
                        <p class="op-text-muted op-text-sm">Connect your mobile companion app to start forwarding SMS messages.</p>
                        <button class="op-btn op-btn-sm op-btn-primary op-mt-2" onclick="document.getElementById('pair-device-btn').click()">Pair First Device</button>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% endblock %}
{% block scripts %}<script src="/assets/js/pages/devices.js"></script>{% endblock %}
