{% extends 'admin/layout/base.twig' %}
{% block title %}{{ merchant.id ? 'Edit' : 'Create' }} Merchant — {{ app_name }}{% endblock %}
{% block content %}
<div class="op-page-header">
    <h1>{{ merchant.id ? 'Edit: ' ~ merchant.business_name : 'Create Merchant' }}</h1>
    <a href="/admin/merchants" class="op-btn op-btn-outline">← Back</a>
</div>
<form method="POST" action="/admin/merchants/{{ merchant.id ? merchant.id ~ '/edit' : 'create' }}" class="op-form">
    <input type="hidden" name="_csrf" value="{{ csrf_token }}">
    <div class="op-card op-mb-4">
        <div class="op-card-header"><h3>Business Info</h3></div>
        <div class="op-card-body">
            <div class="op-form-row">
                <div class="op-form-group op-col-6">
                    <label>Business Name *</label>
                    <input type="text" name="business_name" value="{{ merchant.business_name ?? '' }}" class="op-input" required>
                </div>
                <div class="op-form-group op-col-6">
                    <label>Contact Email</label>
                    <input type="email" name="email" value="{{ merchant.email ?? '' }}" class="op-input">
                </div>
            </div>
            <div class="op-form-row">
                <div class="op-form-group op-col-6">
                    <label>Phone</label>
                    <input type="tel" name="phone" value="{{ merchant.phone ?? '' }}" class="op-input">
                </div>
                <div class="op-form-group op-col-6">
                    <label>Status</label>
                    <select name="status" class="op-input">
                        <option value="active" {{ (merchant.status ?? 'active') == 'active' ? 'selected' : '' }}>Active</option>
                        <option value="suspended" {{ (merchant.status ?? '') == 'suspended' ? 'selected' : '' }}>Suspended</option>
                        <option value="inactive" {{ (merchant.status ?? '') == 'inactive' ? 'selected' : '' }}>Inactive</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    {% if merchant.id %}
    <div class="op-card op-mb-4">
        <div class="op-card-header"><h3>Custom Domain</h3></div>
        <div class="op-card-body">
            {% if merchant.domain %}
            <dl class="op-detail-list">
                <dt>Domain</dt><dd><code>{{ merchant.domain }}</code></dd>
                <dt>DNS Status</dt><dd><span class="op-badge op-badge-{{ merchant.dns_verified ? 'success' : 'warning' }}">{{ merchant.dns_verified ? 'Verified' : 'Pending' }}</span></dd>
            </dl>
            {% else %}
            <p class="op-text-muted">No custom domain configured. <a href="/admin/domains">Manage domains →</a></p>
            {% endif %}
        </div>
    </div>
    {% endif %}

    <div class="op-form-actions">
        <button type="submit" class="op-btn op-btn-primary op-btn-lg">{{ merchant.id ? 'Save' : 'Create' }}</button>
    </div>
</form>
{% endblock %}
