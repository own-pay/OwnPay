{# Onboarding Setup Wizard Component #}
<div id="op-setup-wizard" class="op-setup-wizard-card">
    <button type="button" class="op-wizard-dismiss" title="Dismiss Wizard">×</button>

    <div class="op-wizard-header">
        <div class="op-wizard-title" id="wizard-title">System Setup Wizard</div>
        <div class="op-wizard-subtitle" id="wizard-subtitle">Welcome to OwnPay! Let's get your payment engine professionally configured.</div>
    </div>

    <!-- 5-Step Stepper Progress Bar -->
    <div class="op-wizard-steps">
        <div class="op-wizard-progress-bar" id="wizard-progress-bar"></div>
        <div class="op-wizard-step active" data-step="1">
            1
            <div class="op-wizard-step-label">Platform Settings</div>
        </div>
        <div class="op-wizard-step" data-step="2">
            2
            <div class="op-wizard-step-label">First Brand</div>
        </div>
        <div class="op-wizard-step" data-step="3">
            3
            <div class="op-wizard-step-label">Outgoing Mail</div>
        </div>
        <div class="op-wizard-step" data-step="4">
            4
            <div class="op-wizard-step-label">Gateways</div>
        </div>
        <div class="op-wizard-step" data-step="5">
            5
            <div class="op-wizard-step-label">Device Pairing</div>
        </div>
    </div>

    <!-- Notification Messages -->
    <div class="op-wizard-error" id="wizard-error">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
        <span id="wizard-error-text"></span>
    </div>
    <div class="op-wizard-success" id="wizard-success">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <span id="wizard-success-text"></span>
    </div>

    <!-- STEP 1 PANEL: Expanded Platform Settings -->
    <div class="op-wizard-panel active" id="panel-1">
        <form id="form-step-1">
            <div class="op-wizard-form-grid">
                <div class="op-wizard-field">
                    <label class="op-wizard-label" for="site_name">System Name</label>
                    <input type="text" id="site_name" name="site_name" class="op-wizard-input" value="{{ app_name }}" required placeholder="e.g. My Payment Gateway">
                    <div class="op-wizard-hint">The primary name for the platform.</div>
                </div>
                <div class="op-wizard-field">
                    <label class="op-wizard-label" for="site_tagline">System Tagline</label>
                    <input type="text" id="site_tagline" name="site_tagline" class="op-wizard-input" value="Enterprise Payment Gateway" placeholder="e.g. Sovereign Payments Engine">
                    <div class="op-wizard-hint">Tagline description displayed on customer receipts & emails.</div>
                </div>
                <div class="op-wizard-field">
                    <label class="op-wizard-label" for="base_currency">Base Currency</label>
                    <select id="base_currency" name="currency" class="op-wizard-select" required>
                        {% for cur in currencies %}
                            <option value="{{ cur.code }}" {{ cur.code == 'USD' ? 'selected' : '' }}>{{ cur.code }} — {{ cur.name }}</option>
                        {% endfor %}
                    </select>
                    <div class="op-wizard-hint">Operational baseline currency for system double-entry ledger bookkeeping.</div>
                </div>
                <div class="op-wizard-field">
                    <label class="op-wizard-label" for="timezone">Platform Timezone</label>
                    <select id="timezone" name="timezone" class="op-wizard-select" required>
                        {% for tz_code, tz_name in timezones %}
                            <option value="{{ tz_code }}" {{ tz_code == 'UTC' ? 'selected' : '' }}>{{ tz_name }}</option>
                        {% endfor %}
                    </select>
                    <div class="op-wizard-hint">Default timezone used for system logs and ledger reconciliation audits.</div>
                </div>
                <div class="op-wizard-field">
                    <label class="op-wizard-label" for="timer_minutes">Checkout Expiry Limit</label>
                    <input type="number" id="timer_minutes" name="timer_minutes" class="op-wizard-input" value="10" min="1" required placeholder="e.g. 10">
                    <div class="op-wizard-hint">Number of minutes an end-user checkout session is valid before token expiry.</div>
                </div>
                <div class="op-wizard-field">
                    <label class="op-wizard-label">Require Customer Phone</label>
                    <div class="op-wizard-toggle-wrapper">
                        <label class="op-wizard-switch">
                            <input type="checkbox" id="require_customer_phone" name="require_customer_phone" value="1">
                            <span class="op-wizard-slider"></span>
                        </label>
                        <span class="op-wizard-hint op-wizard-hint-mt-0">Enforce typing a valid phone number during payments.</span>
                    </div>
                </div>
                <div class="op-wizard-field-full">
                    <label class="op-wizard-label">Public Landing Page</label>
                    <div class="op-wizard-toggle-wrapper">
                        <label class="op-wizard-switch">
                            <input type="checkbox" id="landing_page_enabled" name="landing_page_enabled" value="1" checked>
                            <span class="op-wizard-slider"></span>
                        </label>
                        <span class="op-wizard-hint op-wizard-hint-mt-0">Enable the default public-facing home page instead of routing directly to the login portal.</span>
                    </div>
                </div>
            </div>
            <div class="op-wizard-actions">
                <div></div>
                <button type="submit" class="op-wizard-btn op-wizard-btn-next">
                    Continue to Brand
                    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </button>
            </div>
        </form>
    </div>

    <!-- STEP 2 PANEL: Create First Brand -->
    <div class="op-wizard-panel" id="panel-2">
        <form id="form-step-2">
            <div class="op-wizard-form-grid">
                <div class="op-wizard-field">
                    <label class="op-wizard-label" for="brand_name">Brand Name</label>
                    <input type="text" id="brand_name" name="brand_name" class="op-wizard-input" required placeholder="e.g. Acme Store">
                    <div class="op-wizard-hint">Your first white-labeled checkout brand/merchant portal name.</div>
                </div>
                <div class="op-wizard-field">
                    <label class="op-wizard-label" for="brand_email">Support Email</label>
                    <input type="email" id="brand_email" name="brand_email" class="op-wizard-input" required placeholder="support@acmestore.com">
                    <div class="op-wizard-hint">Public contact email for customer billing and receipt inquiries.</div>
                </div>
                <div class="op-wizard-field">
                    <label class="op-wizard-label" for="brand_phone">Support Phone</label>
                    <input type="text" id="brand_phone" name="brand_phone" class="op-wizard-input" placeholder="+1234567890">
                    <div class="op-wizard-hint">Public support phone shown on client checkout invoices (optional).</div>
                </div>
                <div class="op-wizard-field">
                    <label class="op-wizard-label" for="brand_currency">Brand Currency</label>
                    <select id="brand_currency" name="brand_currency" class="op-wizard-select" required>
                        {% for cur in currencies %}
                            <option value="{{ cur.code }}" {{ cur.code == 'USD' ? 'selected' : '' }}>{{ cur.code }} — {{ cur.name }}</option>
                        {% endfor %}
                    </select>
                    <div class="op-wizard-hint">Primary baseline checkout currency for this brand.</div>
                </div>
                <div class="op-wizard-field-full">
                    <label class="op-wizard-label" for="brand_timezone">Brand Timezone</label>
                    <select id="brand_timezone" name="brand_timezone" class="op-wizard-select" required>
                        {% for tz_code, tz_name in timezones %}
                            <option value="{{ tz_code }}" {{ tz_code == 'UTC' ? 'selected' : '' }}>{{ tz_name }}</option>
                        {% endfor %}
                    </select>
                    <div class="op-wizard-hint">Timezone for reporting transactions within this brand portal.</div>
                </div>
            </div>
            <div class="op-wizard-actions">
                <button type="button" class="op-wizard-btn op-wizard-btn-prev" data-prev-step="1">
                    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
                    Back
                </button>
                <button type="submit" class="op-wizard-btn op-wizard-btn-next">
                    Continue to Mail Setup
                    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </button>
            </div>
        </form>
    </div>

    <!-- STEP 3 PANEL: Dedicated Outgoing Mail Configuration -->
    <div class="op-wizard-panel" id="panel-3">
        <form id="form-step-3">
            <div class="op-choice-cards">
                <div class="op-choice-card selected" id="choice-mail-smtp" data-provider="smtp">
                    <div class="op-choice-check">
                        <svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                    </div>
                    <div class="op-choice-icon">📧</div>
                    <div class="op-choice-label">SMTP</div>
                    <div class="op-choice-desc">Custom SMTP Mail Server</div>
                </div>
                <div class="op-choice-card" id="choice-mail-mailgun" data-provider="mailgun">
                    <div class="op-choice-check">
                        <svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                    </div>
                    <div class="op-choice-icon">🚀</div>
                    <div class="op-choice-label">Mailgun</div>
                    <div class="op-choice-desc">HTTP Transactional API</div>
                </div>
                <div class="op-choice-card" id="choice-mail-sendgrid" data-provider="sendgrid">
                    <div class="op-choice-check">
                        <svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                    </div>
                    <div class="op-choice-icon">⚡</div>
                    <div class="op-choice-label">SendGrid</div>
                    <div class="op-choice-desc">API Key Delivery</div>
                </div>
            </div>

            <!-- Global Sender Fields -->
            <div class="op-wizard-form-grid op-wizard-form-grid-border">
                <div class="op-wizard-field">
                    <label class="op-wizard-label" for="mail_from_name">From Sender Name</label>
                    <input type="text" id="mail_from_name" class="op-wizard-input" value="Own Pay" required placeholder="e.g. Own Pay Billing">
                    <div class="op-wizard-hint">The display name customer emails are sent from.</div>
                </div>
                <div class="op-wizard-field">
                    <label class="op-wizard-label" for="mail_from_email">From Sender Email</label>
                    <input type="email" id="mail_from_email" class="op-wizard-input" value="noreply@example.com" required placeholder="e.g. billing@yourdomain.com">
                    <div class="op-wizard-hint">Transactional sender email address.</div>
                </div>
            </div>

            <!-- Dynamic SMTP Fields -->
            <div id="mail-smtp-fields" class="op-mail-smtp-fields-class">
                <h4 class="op-wizard-subheading">SMTP Server Details</h4>
                <div class="op-wizard-form-grid">
                    <div class="op-wizard-field">
                        <label class="op-wizard-label" for="mail_smtp_host">SMTP Host</label>
                        <input type="text" id="mail_smtp_host" class="op-wizard-input" placeholder="e.g. smtp.mailtrap.io">
                    </div>
                    <div class="op-wizard-field">
                        <label class="op-wizard-label" for="mail_smtp_port">SMTP Port</label>
                        <input type="number" id="mail_smtp_port" class="op-wizard-input" value="587" placeholder="e.g. 587 or 465">
                    </div>
                    <div class="op-wizard-field">
                        <label class="op-wizard-label" for="mail_smtp_user">SMTP Username</label>
                        <input type="text" id="mail_smtp_user" class="op-wizard-input" placeholder="SMTP login username">
                    </div>
                    <div class="op-wizard-field">
                        <label class="op-wizard-label" for="mail_smtp_password">SMTP Password</label>
                        <input type="password" id="mail_smtp_password" class="op-wizard-input" placeholder="SMTP login password">
                    </div>
                    <div class="op-wizard-field-full">
                        <label class="op-wizard-label" for="mail_smtp_encryption">SMTP Encryption</label>
                        <select id="mail_smtp_encryption" class="op-wizard-select">
                            <option value="tls" selected>TLS (Recommended)</option>
                            <option value="ssl">SSL</option>
                            <option value="none">None</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Dynamic Mailgun Fields -->
            <div id="mail-mailgun-fields" class="op-mail-other-fields-class">
                <h4 class="op-wizard-subheading">Mailgun API Credentials</h4>
                <div class="op-wizard-form-grid">
                    <div class="op-wizard-field">
                        <label class="op-wizard-label" for="mail_mailgun_domain">Sending Domain</label>
                        <input type="text" id="mail_mailgun_domain" class="op-wizard-input" placeholder="e.g. mg.yourdomain.com">
                    </div>
                    <div class="op-wizard-field">
                        <label class="op-wizard-label" for="mail_mailgun_key">Mailgun API Key</label>
                        <input type="password" id="mail_mailgun_key" class="op-wizard-input" placeholder="key-...">
                    </div>
                </div>
            </div>

            <!-- Dynamic SendGrid Fields -->
            <div id="mail-sendgrid-fields" class="op-mail-other-fields-class">
                <h4 class="op-wizard-subheading">SendGrid API Credentials</h4>
                <div class="op-wizard-form-grid">
                    <div class="op-wizard-field-full">
                        <label class="op-wizard-label" for="mail_sendgrid_key">SendGrid API Key</label>
                        <input type="password" id="mail_sendgrid_key" class="op-wizard-input" placeholder="SG....">
                    </div>
                </div>
            </div>

            <div class="op-wizard-actions">
                <button type="button" class="op-wizard-btn op-wizard-btn-prev" data-prev-step="2">
                    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
                    Back
                </button>
                <div class="op-flex-gap-1rem">
                    <button type="button" class="op-wizard-btn op-wizard-btn-prev" id="btn-skip-mail">
                        Skip Mail Setup
                    </button>
                    <button type="submit" class="op-wizard-btn op-wizard-btn-next" id="btn-save-mail">
                        Save & Continue
                        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                    </button>
                </div>
            </div>
        </form>
    </div>

    <!-- STEP 4 PANEL: Gateway Configuration -->
    <div class="op-wizard-panel" id="panel-4">
        <div class="op-choice-cards">
            <div class="op-choice-card" id="choice-stripe" data-gateway="stripe">
                <div class="op-choice-check">
                    <svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </div>
                <div class="op-choice-icon">💳</div>
                <div class="op-choice-label">Stripe API</div>
                <div class="op-choice-desc">Credit & Debit Cards</div>
            </div>
            <div class="op-choice-card" id="choice-paypal" data-gateway="paypal">
                <div class="op-choice-check">
                    <svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </div>
                <div class="op-choice-icon">🅿️</div>
                <div class="op-choice-label">PayPal Checkout</div>
                <div class="op-choice-desc">Express Checkout & Wallet</div>
            </div>
            <div class="op-choice-card" id="choice-manual" data-gateway="manual">
                <div class="op-choice-check">
                    <svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </div>
                <div class="op-choice-icon">🏦</div>
                <div class="op-choice-label">Manual / Bank</div>
                <div class="op-choice-desc">Bank Transfer & Cash</div>
            </div>
        </div>

        <!-- Dynamic configuration sub-forms -->
        <div id="stripe-fields" class="op-gateway-fields-class">
            <h4 class="op-wizard-subheading">Configure Stripe (sandbox mode default)</h4>
            <div class="op-wizard-form-grid">
                <div class="op-wizard-field">
                    <label class="op-wizard-label" for="stripe_key">Publishable Key</label>
                    <input type="text" id="stripe_key" class="op-wizard-input" placeholder="pk_test_...">
                </div>
                <div class="op-wizard-field">
                    <label class="op-wizard-label" for="stripe_secret">Secret Key</label>
                    <input type="password" id="stripe_secret" class="op-wizard-input" placeholder="sk_test_...">
                </div>
            </div>
        </div>

        <div id="paypal-fields" class="op-gateway-fields-class">
            <h4 class="op-wizard-subheading">Configure PayPal Sandbox</h4>
            <div class="op-wizard-form-grid">
                <div class="op-wizard-field">
                    <label class="op-wizard-label" for="paypal_client_id">Client ID</label>
                    <input type="text" id="paypal_client_id" class="op-wizard-input" placeholder="Client ID">
                </div>
                <div class="op-wizard-field">
                    <label class="op-wizard-label" for="paypal_secret">Client Secret</label>
                    <input type="password" id="paypal_secret" class="op-wizard-input" placeholder="Client Secret">
                </div>
            </div>
        </div>

        <div id="manual-fields" class="op-gateway-fields-class">
            <h4 class="op-wizard-subheading">Configure Manual/Bank Transfer</h4>
            <div class="op-wizard-form-grid">
                <div class="op-wizard-field">
                    <label class="op-wizard-label" for="manual_name">Payment Option Name</label>
                    <input type="text" id="manual_name" class="op-wizard-input" value="Bank Transfer">
                </div>
                <div class="op-wizard-field-full">
                    <label class="op-wizard-label" for="manual_details">Payment Details & Instructions</label>
                    <textarea id="manual_details" rows="3" class="op-wizard-textarea" placeholder="Send payments to account: IBAN... Bank Name... instructions for verifying transaction reference."></textarea>
                </div>
            </div>
        </div>

        <div class="op-wizard-actions">
            <button type="button" class="op-wizard-btn op-wizard-btn-prev" data-prev-step="3">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
                Back
            </button>
            <button type="button" class="op-wizard-btn op-wizard-btn-next" id="btn-save-gateway">
                Save & Continue
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </button>
        </div>
    </div>

    <!-- STEP 5 PANEL: Device Pairing / Complete -->
    <div class="op-wizard-panel" id="panel-5">
        <div class="op-pairing-container">
            <div class="op-qr-mock">
                <!-- Placeholder SVG first, replaced dynamically by loaded QR Code IMG -->
                <svg id="op-wizard-qr-placeholder" class="op-qr-svg" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                    <rect width="100" height="100" fill="#ffffff"/>
                    <!-- QR markers -->
                    <rect x="5" y="5" width="20" height="20" fill="#111827" />
                    <rect x="8" y="8" width="14" height="14" fill="#ffffff" />
                    <rect x="11" y="11" width="8" height="8" fill="#6366f1" />
                    
                    <rect x="75" y="5" width="20" height="20" fill="#111827" />
                    <rect x="78" y="8" width="14" height="14" fill="#ffffff" />
                    <rect x="81" y="11" width="8" height="8" fill="#6366f1" />
                    
                    <rect x="5" y="75" width="20" height="20" fill="#111827" />
                    <rect x="8" y="78" width="14" height="14" fill="#ffffff" />
                    <rect x="11" y="81" width="8" height="8" fill="#6366f1" />
 
                    <rect x="75" y="75" width="20" height="20" fill="#111827" />
                    <rect x="78" y="78" width="14" height="14" fill="#ffffff" />
                    
                    <!-- Simulating QR noise -->
                    <path d="M30,5 h5 v5 h-5 z M35,10 h5 v5 h-5 z M45,5 h10 v5 h-10 z M60,5 h10 v5 h-10 z M30,20 h5 v5 h-5 z M40,25 h15 v5 h-15 z M65,20 h5 v5 h-5 z M30,35 h10 v5 h-10 z M50,35 h5 v5 h-5 z M60,35 h15 v5 h-15 z M5,30 h10 v5 h-10 z M15,40 h5 v5 h-5 z M25,45 h10 v5 h-10 z M40,45 h5 v5 h-5 z M55,45 h10 v5 h-10 z M70,45 h5 v5 h-5 z M10,55 h15 v5 h-15 z M30,55 h5 v5 h-5 z M45,55 h10 v5 h-10 z M65,55 h10 v5 h-10 z M5,65 h5 v5 h-5 z M20,65 h10 v5 h-10 z M40,65 h5 v5 h-5 z M50,65 h10 v5 h-10 z M65,65 h5 v5 h-5 z M35,75 h5 v5 h-5 z M45,75 h15 v5 h-15 z M65,75 h5 v5 h-5 z" fill="#111827"/>
                    <!-- Central branded visual accent -->
                    <rect x="42" y="42" width="16" height="16" rx="4" fill="#6366f1" />
                    <circle cx="50" cy="50" r="4" fill="#ffffff" />
                </svg>
                <img id="op-wizard-qr-img" class="op-qr-svg op-qr-svg-img" alt="Dynamic QR Code" />
            </div>
            <div class="op-pairing-text">
                <h4>Pair Mobile Companion Device</h4>
                <p>OwnPay includes a secure native companion app to monitor transactional logs, run double-entry audits, and pair SMS routing. Take advantage of automated SMS tracking today!</p>
                <div class="op-pairing-steps">
                    <div class="op-pairing-step-item">
                        <div class="op-pairing-step-num">1</div>
                        <div>Download OwnPay Companion App from Play Store or App Store.</div>
                    </div>
                    <div class="op-pairing-step-item">
                        <div class="op-pairing-step-num">2</div>
                        <div>Open Companion App and select **"Pair Device via QR"**.</div>
                    </div>
                    <div class="op-pairing-step-item">
                        <div class="op-pairing-step-num">3</div>
                        <div>Scan the QR code on the left to securely couple this environment.</div>
                    </div>
                    <!-- OTP Fallback display -->
                    <div id="op-wizard-otp-wrapper" class="op-otp-wrapper">
                        <span class="op-otp-label-header">
                            <span>Manual OTP Fallback Code</span>
                            <span id="op-wizard-otp-copied" class="op-otp-copied-text">Copied!</span>
                        </span>
                        <div class="op-otp-flex-row">
                            <span id="op-wizard-otp-display" class="op-otp-display-span" title="Click to Copy">------</span>
                            <span id="op-wizard-otp-timer" class="op-otp-timer-span">Expires in 5:00</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
 
        <div class="op-wizard-actions">
            <button type="button" class="op-wizard-btn op-wizard-btn-prev" data-prev-step="4">
