{# Onboarding Setup Wizard Component #}
<div id="op-setup-wizard" class="op-setup-wizard-card">
    <style nonce="{{ csp_nonce }}">
        .op-setup-wizard-card {
            background: linear-gradient(135deg, rgba(17, 24, 39, 0.85) 0%, rgba(31, 41, 55, 0.9) 100%);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 20px;
            padding: 3rem;
            margin-bottom: 3rem;
            box-shadow: 0 20px 50px -12px rgba(0, 0, 0, 0.5), 
                        inset 0 1px 1px 0 rgba(255, 255, 255, 0.05);
            color: #f3f4f6;
            position: relative;
            overflow: hidden;
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
            animation: slideInDown 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }

        @keyframes slideInDown {
            from {
                transform: translateY(-30px);
                opacity: 0;
            }
            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .op-wizard-dismiss {
            position: absolute;
            top: 1.5rem;
            right: 1.5rem;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.05);
            color: #9ca3af;
            font-size: 1.25rem;
            cursor: pointer;
            width: 2.25rem;
            height: 2.25rem;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .op-wizard-dismiss:hover {
            background: rgba(239, 68, 68, 0.15);
            border-color: rgba(239, 68, 68, 0.3);
            color: #ef4444;
            transform: rotate(90deg);
        }

        .op-wizard-header {
            margin-bottom: 2.5rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            padding-bottom: 1.5rem;
        }

        .op-wizard-title {
            font-size: 2rem;
            font-weight: 800;
            background: linear-gradient(135deg, #cbd5e1 0%, #6366f1 50%, #a5b4fc 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 0.5rem;
            letter-spacing: -0.02em;
        }

        .op-wizard-subtitle {
            color: #9ca3af;
            font-size: 1rem;
            line-height: 1.5;
        }

        /* Progress Steps Stepper */
        .op-wizard-steps {
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: relative;
            margin-bottom: 3.5rem;
            padding: 0 1.5rem;
        }

        .op-wizard-steps::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 0;
            right: 0;
            height: 2px;
            background: rgba(255, 255, 255, 0.06);
            transform: translateY(-50%);
            z-index: 1;
        }

        .op-wizard-progress-bar {
            position: absolute;
            top: 50%;
            left: 0;
            width: 0%;
            height: 2px;
            background: linear-gradient(90deg, #6366f1, #818cf8, #a5b4fc);
            transform: translateY(-50%);
            z-index: 2;
            transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .op-wizard-step {
            position: relative;
            z-index: 3;
            background: #111827;
            border: 2px solid rgba(255, 255, 255, 0.08);
            color: #9ca3af;
            width: 3rem;
            height: 3rem;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 1rem;
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .op-wizard-step.active {
            border-color: #6366f1;
            color: #ffffff;
            background: #6366f1;
            box-shadow: 0 0 25px rgba(99, 102, 241, 0.45);
            transform: scale(1.1);
        }

        .op-wizard-step.completed {
            border-color: #10b981;
            color: #ffffff;
            background: #10b981;
            box-shadow: 0 0 20px rgba(16, 185, 129, 0.3);
        }

        .op-wizard-step-label {
            position: absolute;
            top: 3.5rem;
            white-space: nowrap;
            font-size: 0.8rem;
            font-weight: 600;
            color: #6b7280;
            transform: translateX(-50%);
            left: 50%;
            transition: all 0.3s ease;
        }

        .op-wizard-step.active .op-wizard-step-label {
            color: #a5b4fc;
            font-weight: 700;
        }

        .op-wizard-step.completed .op-wizard-step-label {
            color: #10b981;
        }

        /* Step Panels */
        .op-wizard-panel {
            display: none;
            animation: panelFadeIn 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .op-wizard-panel.active {
            display: block;
        }

        @keyframes panelFadeIn {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Form Controls */
        .op-wizard-form-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1.75rem;
            margin-bottom: 2.5rem;
        }

        @media (max-width: 768px) {
            .op-wizard-form-grid {
                grid-template-columns: 1fr;
            }
        }

        .op-wizard-field {
            display: flex;
            flex-direction: column;
            gap: 0.6rem;
        }

        .op-wizard-field-full {
            grid-column: 1 / -1;
            display: flex;
            flex-direction: column;
            gap: 0.6rem;
        }

        .op-wizard-label {
            font-size: 0.8rem;
            font-weight: 700;
            color: #d1d5db;
            text-transform: uppercase;
            letter-spacing: 0.06em;
        }

        .op-wizard-input, .op-wizard-select, .op-wizard-textarea {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.08);
            color: #f3f4f6;
            padding: 0.85rem 1.1rem;
            border-radius: 10px;
            font-size: 0.95rem;
            outline: none;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            width: 100%;
        }

        .op-wizard-input:focus, .op-wizard-select:focus, .op-wizard-textarea:focus {
            border-color: #6366f1;
            background: rgba(255, 255, 255, 0.05);
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.25);
        }

        .op-wizard-select option {
            background: #111827;
            color: #f3f4f6;
        }

        .op-wizard-hint {
            font-size: 0.8rem;
            color: #9ca3af;
            line-height: 1.4;
        }

        /* Toggle Switches */
        .op-wizard-toggle-wrapper {
            display: flex;
            align-items: center;
            gap: 1rem;
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.05);
            padding: 1rem;
            border-radius: 10px;
            transition: all 0.3s ease;
        }

        .op-wizard-toggle-wrapper:hover {
            background: rgba(255, 255, 255, 0.04);
            border-color: rgba(255, 255, 255, 0.08);
        }

        .op-wizard-switch {
            position: relative;
            display: inline-block;
            width: 2.75rem;
            height: 1.5rem;
            flex-shrink: 0;
        }

        .op-wizard-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

        .op-wizard-slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: rgba(255, 255, 255, 0.1);
            transition: .3s cubic-bezier(0.4, 0, 0.2, 1);
            border-radius: 34px;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .op-wizard-slider:before {
            position: absolute;
            content: "";
            height: 1.1rem;
            width: 1.1rem;
            left: 2px;
            bottom: 1.5px;
            background-color: #cbd5e1;
            transition: .3s cubic-bezier(0.4, 0, 0.2, 1);
            border-radius: 50%;
        }

        input:checked + .op-wizard-slider {
            background-color: #6366f1;
            border-color: rgba(99, 102, 241, 0.3);
        }

        input:checked + .op-wizard-slider:before {
            transform: translateX(1.15rem);
            background-color: #ffffff;
        }

        /* Action Buttons */
        .op-wizard-actions {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            padding-top: 2rem;
            margin-top: 2.5rem;
        }

        .op-wizard-btn {
            padding: 0.85rem 1.75rem;
            border-radius: 10px;
            font-weight: 700;
            font-size: 0.95rem;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            align-items: center;
            gap: 0.6rem;
            border: none;
        }

        .op-wizard-btn-prev {
            background: rgba(255, 255, 255, 0.04);
            color: #d1d5db;
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .op-wizard-btn-prev:hover {
            background: rgba(255, 255, 255, 0.08);
            color: #ffffff;
            border-color: rgba(255, 255, 255, 0.15);
        }

        .op-wizard-btn-next {
            background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
            color: #ffffff;
            box-shadow: 0 4px 15px rgba(99, 102, 241, 0.35);
        }

        .op-wizard-btn-next:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(99, 102, 241, 0.45);
        }

        .op-wizard-btn-finish {
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            color: #ffffff;
            box-shadow: 0 4px 15px rgba(16, 185, 129, 0.35);
        }

        .op-wizard-btn-finish:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(16, 185, 129, 0.45);
        }

        .op-wizard-btn:disabled {
            opacity: 0.4;
            cursor: not-allowed;
            transform: none !important;
            box-shadow: none !important;
        }

        /* Choice Cards for Gateways and Outgoing Mail */
        .op-choice-cards {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.25rem;
            margin-bottom: 2.5rem;
        }

        @media (max-width: 768px) {
            .op-choice-cards {
                grid-template-columns: 1fr;
            }
        }

        .op-choice-card {
            background: rgba(255, 255, 255, 0.02);
            border: 2px solid rgba(255, 255, 255, 0.05);
            border-radius: 14px;
            padding: 1.75rem;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .op-choice-card:hover {
            background: rgba(255, 255, 255, 0.05);
            border-color: rgba(99, 102, 241, 0.3);
            transform: translateY(-2px);
        }

        .op-choice-card.selected {
            background: rgba(99, 102, 241, 0.08);
            border-color: #6366f1;
            box-shadow: 0 0 20px rgba(99, 102, 241, 0.2);
        }

        .op-choice-icon {
            font-size: 2.25rem;
            margin-bottom: 0.75rem;
            filter: drop-shadow(0 2px 8px rgba(99, 102, 241, 0.3));
        }

        .op-choice-label {
            font-weight: 700;
            font-size: 1.05rem;
            color: #f9fafb;
            margin-bottom: 0.25rem;
        }

        .op-choice-desc {
            font-size: 0.8rem;
            color: #9ca3af;
        }

        .op-choice-check {
            position: absolute;
            top: 0.75rem;
            right: 0.75rem;
            width: 1.35rem;
            height: 1.35rem;
            border-radius: 50%;
            background: #6366f1;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            transform: scale(0.8);
        }

        .op-choice-card.selected .op-choice-check {
            opacity: 1;
            transform: scale(1);
        }

        .op-choice-check svg {
            width: 0.8rem;
            height: 0.8rem;
            fill: none;
            stroke: #ffffff;
            stroke-width: 3.5;
        }

        /* Device step QR and details */
        .op-pairing-container {
            display: flex;
            gap: 2.5rem;
            align-items: center;
            background: rgba(255, 255, 255, 0.01);
            border-radius: 16px;
            padding: 2rem;
            border: 1px solid rgba(255, 255, 255, 0.04);
        }

        @media (max-width: 640px) {
            .op-pairing-container {
                flex-direction: column;
                text-align: center;
            }
        }

        .op-qr-mock {
            background: #ffffff;
            padding: 1rem;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 15px 35px rgba(0,0,0,0.4);
            flex-shrink: 0;
            transition: all 0.3s ease;
        }

        .op-qr-mock:hover {
            transform: scale(1.03);
        }

        .op-qr-svg {
            width: 150px;
            height: 150px;
        }

        .op-pairing-text h4 {
            font-size: 1.25rem;
            font-weight: 700;
            margin-bottom: 0.75rem;
            color: #ffffff;
            letter-spacing: -0.01em;
        }

        .op-pairing-text p {
            color: #9ca3af;
            font-size: 0.95rem;
            line-height: 1.6;
            margin-bottom: 1.5rem;
        }

        .op-pairing-steps {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            text-align: left;
        }

        .op-pairing-step-item {
            display: flex;
            gap: 0.9rem;
            font-size: 0.9rem;
            color: #d1d5db;
            align-items: center;
        }

        .op-pairing-step-num {
            background: rgba(99, 102, 241, 0.25);
            color: #a5b4fc;
            width: 1.5rem;
            height: 1.5rem;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.8rem;
            flex-shrink: 0;
            border: 1px solid rgba(99, 102, 241, 0.15);
        }

        .op-wizard-error {
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.25);
            border-radius: 10px;
            padding: 1rem 1.25rem;
            color: #fca5a5;
            font-size: 0.95rem;
            margin-bottom: 2rem;
            display: none;
            align-items: center;
            gap: 0.75rem;
            animation: shake 0.5s ease-in-out;
        }

        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            20%, 60% { transform: translateX(-6px); }
            40%, 80% { transform: translateX(6px); }
        }

        .op-wizard-success {
            background: rgba(16, 185, 129, 0.1);
            border: 1px solid rgba(16, 185, 129, 0.25);
            border-radius: 10px;
            padding: 1rem 1.25rem;
            color: #a7f3d0;
            font-size: 0.95rem;
            margin-bottom: 2rem;
            display: none;
            align-items: center;
            gap: 0.75rem;
        }
    </style>

    <button type="button" class="op-wizard-dismiss" onclick="dismissWizard()" title="Dismiss Wizard">×</button>

    <div class="op-wizard-header">
        <div class="op-wizard-title" id="wizard-title">System Setup Wizard</div>
        <div class="op-wizard-subtitle" id="wizard-subtitle">Welcome to OwnPay! Let's get your payment engine professionally configured.</div>
    </div>

    <!-- 5-Step Stepper Progress Bar -->
    <div class="op-wizard-steps">
        <div class="op-wizard-progress-bar" id="wizard-progress-bar"></div>
        <div class="op-wizard-step active" data-step="1">
            1
            <div class="op-wizard-step-label">Platform Settings</div>
        </div>
        <div class="op-wizard-step" data-step="2">
            2
            <div class="op-wizard-step-label">First Brand</div>
        </div>
        <div class="op-wizard-step" data-step="3">
            3
            <div class="op-wizard-step-label">Outgoing Mail</div>
        </div>
        <div class="op-wizard-step" data-step="4">
            4
            <div class="op-wizard-step-label">Gateways</div>
        </div>
        <div class="op-wizard-step" data-step="5">
            5
            <div class="op-wizard-step-label">Device Pairing</div>
        </div>
    </div>

    <!-- Notification Messages -->
    <div class="op-wizard-error" id="wizard-error">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
        <span id="wizard-error-text"></span>
    </div>
    <div class="op-wizard-success" id="wizard-success">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <span id="wizard-success-text"></span>
    </div>

    <!-- STEP 1 PANEL: Expanded Platform Settings -->
    <div class="op-wizard-panel active" id="panel-1">
        <form id="form-step-1" onsubmit="event.preventDefault(); submitStep1();">
            <div class="op-wizard-form-grid">
                <div class="op-wizard-field">
                    <label class="op-wizard-label" for="site_name">System Name</label>
                    <input type="text" id="site_name" name="site_name" class="op-wizard-input" value="{{ app_name }}" required placeholder="e.g. My Payment Gateway">
                    <div class="op-wizard-hint">The primary name for the platform.</div>
                </div>
                <div class="op-wizard-field">
                    <label class="op-wizard-label" for="site_tagline">System Tagline</label>
                    <input type="text" id="site_tagline" name="site_tagline" class="op-wizard-input" value="Enterprise Payment Gateway" placeholder="e.g. Sovereign Payments Engine">
                    <div class="op-wizard-hint">Tagline description displayed on customer receipts & emails.</div>
                </div>
                <div class="op-wizard-field">
                    <label class="op-wizard-label" for="base_currency">Base Currency</label>
                    <select id="base_currency" name="currency" class="op-wizard-select" required>
                        {% for cur in currencies %}
                            <option value="{{ cur.code }}" {{ cur.code == 'USD' ? 'selected' : '' }}>{{ cur.code }} — {{ cur.name }}</option>
                        {% endfor %}
                    </select>
                    <div class="op-wizard-hint">Operational baseline currency for system double-entry ledger bookkeeping.</div>
                </div>
                <div class="op-wizard-field">
                    <label class="op-wizard-label" for="timezone">Platform Timezone</label>
                    <select id="timezone" name="timezone" class="op-wizard-select" required>
                        {% for tz_code, tz_name in timezones %}
                            <option value="{{ tz_code }}" {{ tz_code == 'UTC' ? 'selected' : '' }}>{{ tz_name }}</option>
                        {% endfor %}
                    </select>
                    <div class="op-wizard-hint">Default timezone used for system logs and ledger reconciliation audits.</div>
                </div>
                <div class="op-wizard-field">
                    <label class="op-wizard-label" for="timer_minutes">Checkout Expiry Limit</label>
                    <input type="number" id="timer_minutes" name="timer_minutes" class="op-wizard-input" value="10" min="1" required placeholder="e.g. 10">
                    <div class="op-wizard-hint">Number of minutes an end-user checkout session is valid before token expiry.</div>
                </div>
                <div class="op-wizard-field">
                    <label class="op-wizard-label">Require Customer Phone</label>
                    <div class="op-wizard-toggle-wrapper">
                        <label class="op-wizard-switch">
                            <input type="checkbox" id="require_customer_phone" name="require_customer_phone" value="1">
                            <span class="op-wizard-slider"></span>
                        </label>
                        <span class="op-wizard-hint" style="margin-top: 0;">Enforce typing a valid phone number during payments.</span>
                    </div>
                </div>
                <div class="op-wizard-field-full">
                    <label class="op-wizard-label">Public Landing Page</label>
                    <div class="op-wizard-toggle-wrapper">
                        <label class="op-wizard-switch">
                            <input type="checkbox" id="landing_page_enabled" name="landing_page_enabled" value="1" checked>
                            <span class="op-wizard-slider"></span>
                        </label>
                        <span class="op-wizard-hint" style="margin-top: 0;">Enable the default public-facing home page instead of routing directly to the login portal.</span>
                    </div>
                </div>
            </div>
            <div class="op-wizard-actions">
                <div></div>
                <button type="submit" class="op-wizard-btn op-wizard-btn-next">
                    Continue to Brand
                    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </button>
            </div>
        </form>
    </div>

    <!-- STEP 2 PANEL: Create First Brand -->
    <div class="op-wizard-panel" id="panel-2">
        <form id="form-step-2" onsubmit="event.preventDefault(); submitStep2();">
            <div class="op-wizard-form-grid">
                <div class="op-wizard-field">
                    <label class="op-wizard-label" for="brand_name">Brand Name</label>
                    <input type="text" id="brand_name" name="brand_name" class="op-wizard-input" required placeholder="e.g. Acme Store">
                    <div class="op-wizard-hint">Your first white-labeled checkout brand/merchant portal name.</div>
                </div>
                <div class="op-wizard-field">
                    <label class="op-wizard-label" for="brand_email">Support Email</label>
                    <input type="email" id="brand_email" name="brand_email" class="op-wizard-input" required placeholder="support@acmestore.com">
                    <div class="op-wizard-hint">Public contact email for customer billing and receipt inquiries.</div>
                </div>
                <div class="op-wizard-field">
                    <label class="op-wizard-label" for="brand_phone">Support Phone</label>
                    <input type="text" id="brand_phone" name="brand_phone" class="op-wizard-input" placeholder="+1234567890">
                    <div class="op-wizard-hint">Public support phone shown on client checkout invoices (optional).</div>
                </div>
                <div class="op-wizard-field">
                    <label class="op-wizard-label" for="brand_currency">Brand Currency</label>
                    <select id="brand_currency" name="brand_currency" class="op-wizard-select" required>
                        {% for cur in currencies %}
                            <option value="{{ cur.code }}" {{ cur.code == 'USD' ? 'selected' : '' }}>{{ cur.code }} — {{ cur.name }}</option>
                        {% endfor %}
