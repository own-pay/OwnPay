<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Checkout{% endblock %} — {{ app_name|default('Own Pay') }}</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: #334155;
            padding: 1rem;
        }
        .checkout-wrapper {
            width: 100%;
            max-width: 480px;
        }
        .checkout-brand {
            text-align: center;
            margin-bottom: 1.5rem;
        }
        .checkout-brand h1 {
            font-size: 1.5rem;
            font-weight: 700;
            color: #fff;
            letter-spacing: -0.025em;
        }
        .checkout-brand .brand-sub {
            color: #94a3b8;
            font-size: 0.875rem;
            margin-top: 0.25rem;
        }
        .checkout-card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            padding: 2rem;
            width: 100%;
        }
        .checkout-footer {
            text-align: center;
            margin-top: 1.5rem;
            color: #64748b;
            font-size: 0.75rem;
        }
        .checkout-footer a { color: #94a3b8; text-decoration: none; }
        @media (max-width: 520px) {
            .checkout-card { padding: 1.5rem; border-radius: 12px; }
        }
    </style>
    {% block head %}{% endblock %}
</head>
<body>
    <div class="checkout-wrapper">
        <div class="checkout-brand">
            <h1>{{ app_name|default('Own Pay') }}</h1>
            <div class="brand-sub">Secure Payment</div>
        </div>
        {% block content %}{% endblock %}
        <div class="checkout-footer">
            Powered by {{ app_name|default('Own Pay') }} &middot; <a href="/">Home</a>
        </div>
    </div>
</body>
</html>
