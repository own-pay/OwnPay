{% macro render_manual_gateway(gateway, transaction) %}
{# Dynamic manual gateway checkout form — rendered from JSON field config #}
<div class="op-checkout-gateway" 
     style="--gw-primary: {{ gateway.colors.primary ?? '#E2136E' }};
            --gw-secondary: {{ gateway.colors.secondary ?? '#FFFFFF' }};
            --gw-text: {{ gateway.colors.text ?? '#FFFFFF' }};">

    <div class="op-gateway-checkout-header" style="background: var(--gw-primary); color: var(--gw-text);">
        {% if gateway.logo_path %}
            <img src="{{ gateway.logo_path }}" alt="{{ gateway.name }}" class="op-gateway-checkout-logo">
        {% endif %}
        <h3>{{ gateway.name }}</h3>
    </div>

    <div class="op-gateway-checkout-body">
        {% if gateway.instructions %}
        <div class="op-gateway-instructions">
            <p>{{ gateway.instructions|nl2br }}</p>
        </div>
        {% endif %}

        {% if gateway.qr_code_path %}
        <div class="op-gateway-qr">
            <img src="{{ gateway.qr_code_path }}" alt="Scan to pay" class="op-qr-image">
            <small>Scan QR code to pay</small>
        </div>
        {% endif %}

        <div class="op-gateway-amount">
            <span class="op-amount-label">Amount to pay:</span>
            <span class="op-amount-value">{{ transaction.currency }} {{ transaction.amount }}</span>
        </div>

        <form method="POST" action="/checkout/{{ transaction.token }}/submit" 
              enctype="multipart/form-data" class="op-checkout-form">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <input type="hidden" name="gateway_slug" value="{{ gateway.slug }}">

            {% for field in gateway.input_fields %}
            <div class="op-form-group">
                <label for="field_{{ field.name }}">
                    {{ field.label }}
                    {% if field.required %}<span class="op-required">*</span>{% endif %}
                </label>

                {% if field.type == 'file' %}
                    <input type="file" 
                           id="field_{{ field.name }}" 
                           name="{{ field.name }}" 
                           class="op-input-file"
                           {{ field.required ? 'required' : '' }}
                           accept="image/*,.pdf">
                {% elseif field.type == 'tel' %}
                    <input type="tel" 
                           id="field_{{ field.name }}" 
                           name="{{ field.name }}" 
                           class="op-input"
                           {{ field.required ? 'required' : '' }}
                           pattern="[0-9+\-\s()]+"
                           placeholder="{{ field.label }}">
                {% else %}
                    <input type="{{ field.type ?? 'text' }}" 
                           id="field_{{ field.name }}" 
                           name="{{ field.name }}" 
                           class="op-input"
                           {{ field.required ? 'required' : '' }}
                           placeholder="{{ field.label }}">
                {% endif %}
            </div>
            {% endfor %}

            {% if gateway.sms_verification %}
            <div class="op-sms-verify-notice">
                <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M8 1a7 7 0 100 14A7 7 0 008 1zm0 10a1 1 0 110-2 1 1 0 010 2zm1-3.5a.5.5 0 01-1 0V5a.5.5 0 011 0v2.5z"/></svg>
                <span>Your payment will be auto-verified via SMS confirmation.</span>
            </div>
            {% endif %}

            <button type="submit" class="op-btn op-btn-lg op-btn-block" 
                    style="background: var(--gw-primary); color: var(--gw-text);">
                Confirm Payment
            </button>
        </form>
    </div>
</div>
{% endmacro %}
