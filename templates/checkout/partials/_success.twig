{# SUCCESS STATUS #}
<div class="ck-status ck-status-success">
    <div class="ck-status-icon">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#00b894" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
    </div>
    <h2>{{ lang.payment_success ?? 'Payment Successful!' }}</h2>
    <p class="ck-status-amount">{{ txn.currency_symbol ?? '৳' }}{{ txn.amount|default(0)|number_format(2) }}</p>
    {% if txn is defined and txn.trx_id is defined and txn.trx_id %}<p class="ck-status-ref">Ref: {{ txn.trx_id }}</p>{% endif %}
    <p class="ck-status-msg">{{ lang.success_msg ?? 'Your payment has been processed successfully.' }}</p>
</div>
