<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="robots" content="noindex,nofollow">
    <title>{{ status_label ?? (status|capitalize) }} — {{ brand.name ?? 'Own Pay' }}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
    :root{--ink:#080D1A;--ink-2:#1A2038;--ink-3:#2D3555;--ink-4:#4A5578;--mute:#7A84A0;--faint:#A8B0C8;--whisper:#D4D9E8;--cloud:#ECEEF5;--snow:#F5F6FA;--white:#FFF;--teal:#0D9488;--teal-deep:#0A7B70;--teal-pale:#CCFBF1;--font:'Outfit',sans-serif;--mono:'JetBrains Mono',monospace}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:var(--font);background:var(--cloud);color:var(--ink);-webkit-font-smoothing:antialiased;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:16px}
    .st-shell{width:100%;max-width:520px;animation:st-up .6s cubic-bezier(.16,1,.3,1) forwards;opacity:0}
    @keyframes st-up{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}

    /* Card */
    .st-card{border-radius:28px;overflow:hidden;box-shadow:0 32px 72px rgba(0,0,0,.06),0 0 0 1px rgba(0,0,0,.03)}
    .st-header{padding:48px 32px 40px;text-align:center;position:relative}
    .st-icon-wrap{position:relative;width:80px;height:80px;margin:0 auto 24px}
    .st-icon-ring1{position:absolute;inset:-12px;border-radius:50%;opacity:.4}
    .st-icon-ring2{position:absolute;inset:-4px;border-radius:50%;opacity:.6}
    .st-icon-circle{width:80px;height:80px;border-radius:50%;display:flex;align-items:center;justify-content:center;position:relative;z-index:1}
    .st-title{font-size:22px;font-weight:800;margin-bottom:8px;letter-spacing:-.3px}
    .st-subtitle{font-size:13px;color:var(--ink-4);line-height:1.65;max-width:360px;margin:0 auto}

    /* Details */
    .st-body{background:var(--white);padding:0 32px 32px}
    .st-details{background:var(--snow);border-radius:18px;padding:6px}
    .st-row{display:flex;justify-content:space-between;align-items:center;padding:13px 18px;border-radius:12px;transition:background .2s}
    .st-row:hover{background:rgba(0,0,0,.02)}
    .st-row-label{font-size:12px;font-weight:600;color:var(--mute);text-transform:uppercase;letter-spacing:.06em}
    .st-row-value{font-size:13px;font-weight:700;color:var(--ink);font-family:var(--mono);text-align:right;max-width:60%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .st-row-divider{height:1px;background:var(--cloud);margin:0 18px}

    /* Amount highlight */
    .st-amount-row .st-row-value{font-size:17px;font-weight:800;color:var(--ink)}

    /* Actions */
    .st-actions{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:24px;padding:0 32px 32px}
    .st-btn{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;padding:18px 12px;border-radius:18px;border:1.5px solid var(--cloud);background:var(--white);cursor:pointer;transition:all .25s;text-decoration:none;color:var(--ink)}
    .st-btn:hover{border-color:var(--whisper);transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.05)}
    .st-btn-icon{width:38px;height:38px;border-radius:12px;display:flex;align-items:center;justify-content:center}
    .st-btn-label{font-size:12px;font-weight:700;text-align:center;line-height:1.35}

    /* Footer */
    .st-footer{text-align:center;padding:20px;font-size:10px;color:var(--faint);display:flex;align-items:center;justify-content:center;gap:6px}
    .st-footer a{color:var(--ink-4);text-decoration:none;font-weight:600}

    /* Status badge */
    .st-badge{display:inline-flex;align-items:center;gap:5px;padding:5px 14px;border-radius:20px;font-size:11px;font-weight:700;letter-spacing:.04em;margin-bottom:20px}

    /* Spinner */
    @keyframes st-spin{to{transform:rotate(360deg)}}
    .st-spinner{width:28px;height:28px;border:3px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:st-spin .7s linear infinite;margin:0 auto 8px}

    /* Pulse */
    @keyframes st-pulse{0%,100%{opacity:1}50%{opacity:.5}}
    .st-pulse{animation:st-pulse 2s ease infinite}

    /* Responsive */
    @media(max-width:480px){
        .st-header{padding:36px 20px 32px}
        .st-body{padding:0 20px 20px}
        .st-actions{padding:0 20px 20px;gap:10px}
        .st-title{font-size:19px}
        .st-subtitle{font-size:12px}
        .st-row{padding:11px 14px}
        .st-row-label{font-size:11px}
        .st-row-value{font-size:12px}
    }
    </style>
</head>
<body>
    <div class="st-shell">
        {% if status == 'success' or status == 'completed' %}
            {% include 'checkout/partials/_success.twig' %}
        {% elseif status == 'failed' %}
            {% include 'checkout/partials/_failed.twig' %}
        {% elseif status == 'cancelled' or status == 'canceled' %}
            {% include 'checkout/partials/_cancelled.twig' %}
        {% elseif status == 'pending' or status == 'pending_review' or status == 'awaiting_verification' or status == 'processing' %}
            {% include 'checkout/partials/_pending.twig' %}
        {% else %}
            {% include 'checkout/partials/_expired.twig' %}
        {% endif %}
    </div>
</body>
</html>
