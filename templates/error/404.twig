<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>404 — Not Found</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/assets/css/auth.css">
    <style>
        .op-error { text-align: center; padding: 80px 20px; }
        .op-error-code { font-size: 6rem; font-weight: 800; background: linear-gradient(135deg, #6C5CE7, #a29bfe); -webkit-background-clip: text; -webkit-text-fill-color: transparent; line-height: 1; }
        .op-error-msg { font-size: 1.3rem; color: #94a3b8; margin: 16px 0 32px; }
    </style>
</head>
<body class="op-auth-page">
    <div class="op-error">
        <div class="op-error-code">404</div>
        <p class="op-error-msg">Page not found. It may have moved or doesn't exist.</p>
        <a href="/" class="op-btn op-btn-primary op-btn-lg">Go Home</a>
    </div>
</body>
</html>
