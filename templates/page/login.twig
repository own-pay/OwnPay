<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login — {{ app_name ?? 'Own Pay' }}</title>
    <meta name="robots" content="noindex, nofollow">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/assets/css/auth.css">
</head>
<body class="op-auth-page">
    {{ fire_hook('admin.login.render')|raw }}

    <div class="op-auth-container">
        <div class="op-auth-card">
            <div class="op-auth-header">
                <div class="op-logo"><span class="op-logo-icon">OP</span></div>
                <h1>Sign In</h1>
                <p>{{ app_name ?? 'Own Pay' }} Admin Panel</p>
            </div>

            {% if error %}
            <div class="op-alert op-alert-danger">{{ error }}</div>
            {% endif %}

            <form method="POST" action="{{ login_url ?? '/login' }}" class="op-form">
                <input type="hidden" name="_csrf" value="{{ csrf_token }}">

                <div class="op-form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" value="{{ old_email ?? '' }}" class="op-input" required autofocus>
                </div>

                <div class="op-form-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password" class="op-input" required>
                </div>

                <div class="op-form-row op-items-center">
                    <label class="op-checkbox-label">
                        <input type="checkbox" name="remember" value="1">
                        Remember me
                    </label>
                    <a href="/forgot-password" class="op-link">Forgot password?</a>
                </div>

                <button type="submit" class="op-btn op-btn-primary op-btn-lg op-btn-block">Sign In</button>
            </form>
        </div>
    </div>
</body>
</html>
