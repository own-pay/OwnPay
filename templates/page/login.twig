<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - {{ app_name ?? 'OwnPay' }}</title>
    <meta name="robots" content="noindex, nofollow">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/assets/css/tokens.css?v=014">
    <link rel="stylesheet" href="/assets/css/reset.css?v=017">
    <link rel="stylesheet" href="/assets/css/animations.css?v=014">
    <link rel="stylesheet" href="/assets/css/utilities.css?v=014">
    <link rel="stylesheet" href="/assets/css/auth.css?v=015">
    {% if site_favicon is defined and site_favicon %}
    <link rel="icon" href="{{ site_favicon }}" type="image/x-icon">
    {% endif %}
</head>
<body class="op-auth-page">
    {{ hook('admin.login.render')|raw }}

    <div class="op-auth-container">

        <div class="op-visual-panel">
            <div class="op-bg-grid"></div>
            <div class="op-glow-blob-1"></div>
            <div class="op-glow-blob-2"></div>

            <div class="op-brand">
                <div class="op-brand-icon">
                    <img src="/assets/img/logo-dark.svg" alt="{{ app_name ?? 'OwnPay' }}" style="height: 32px; width: auto;">
                </div>
            </div>

            <div class="op-hero-text">
                <div class="op-hero-headline">
                    <p class="op-hero-static">OwnPay</p>
                    <div class="op-rotating-wrapper" id="op-rotating-wrapper">
                        <div class="op-word-track" id="op-word-track"></div>
                    </div>
                </div>
                <p class="op-hero-sub">The payment gateway that puts you in control.</p>
            </div>

            <div class="op-footer-links">
                <a href="#">Privacy Policy</a>
                <a href="#">Terms of Service</a>
                <a href="#">Contact</a>
            </div>
        </div>

        <div class="op-form-panel">
            <div class="op-form-wrapper">

                <div class="op-header-text t-stagger" id="header-stagger">
                    <div class="op-auth-logo">
                        <img src="/assets/img/logo-light.svg" alt="{{ app_name ?? 'OwnPay' }}" class="op-auth-logo-img op-logo-light" style="height: 40px; width: auto;">
                        <img src="/assets/img/logo-dark.svg" alt="{{ app_name ?? 'OwnPay' }}" class="op-auth-logo-img op-logo-dark" style="height: 40px; width: auto;">
                    </div>
                    <h1 class="t-stagger-line t-stagger-line--1">Welcome back!</h1>
                    <p class="t-stagger-line t-stagger-line--2">{{ app_name ?? 'OwnPay' }} Admin Panel</p>
                </div>

                <div class="t-input-wrap" id="error-wrap">
                    {% if error %}
                    <div class="op-alert op-alert-danger t-error-msg">{{ error }}</div>
                    {% endif %}
                </div>

                <form method="POST" action="{{ login_url ?? '/login' }}" id="loginForm">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

                    <div class="op-form-group op-email-group">
                        <label for="email">Email or Username</label>
                        <div class="op-email-input-wrap">
                            <div class="op-stage-wrapper">
                                <div class="op-speech-bubble" id="speech-bubble">
                                    We are actually not looking, it's secure end to end!
                                </div>

                                <div class="op-stage">
                                    <div class="op-character op-char-purple" id="char-purple">
                                        <div class="op-eyes-container" id="eyes-purple">
                                            <div class="op-eye-base"><div class="op-pupil"></div></div>
                                            <div class="op-eye-base"><div class="op-pupil"></div></div>
                                        </div>
                                    </div>

                                    <div class="op-character op-char-black" id="char-black">
                                        <div class="op-eyes-container" id="eyes-black">
                                            <div class="op-eye-base"><div class="op-pupil"></div></div>
                                            <div class="op-eye-base"><div class="op-pupil"></div></div>
                                        </div>
                                    </div>

                                    <div class="op-character op-char-orange" id="char-orange">
                                        <div class="op-eyes-container" id="eyes-orange">
                                            <div class="op-pupil"></div>
                                            <div class="op-pupil"></div>
                                        </div>
                                    </div>

                                    <div class="op-character op-char-yellow" id="char-yellow">
                                        <div class="op-eyes-container" id="eyes-yellow">
                                            <div class="op-pupil"></div>
                                            <div class="op-pupil"></div>
                                        </div>
                                        <div class="op-mouth" id="mouth-yellow"></div>
                                    </div>
                                </div>
                            </div>
                            <input type="text" id="email" name="email" value="{{ old_email ?? '' }}" class="op-input" placeholder="admin@example.com" required autofocus autocomplete="off">
                        </div>
                    </div>

                    <div class="op-form-group">
                        <label for="password">Password</label>
                        <div class="op-input-wrapper">
                            <input type="password" id="password" name="password" class="op-input" placeholder="••••••••" required>
                            <button type="button" class="op-toggle-password" id="togglePassword">
                                <svg id="eye-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                            </button>
                        </div>
                    </div>

                    <div class="op-form-options">
                        <label class="op-checkbox-group">
                            <input type="checkbox" name="remember" value="1">
                            Remember me
                        </label>
                        <a href="/forgot-password" class="op-forgot-link">Forgot password?</a>
                    </div>

                    <button type="submit" class="op-btn op-btn-primary">Sign In</button>
                </form>

                <div class="op-mobile-footer">
                    <a href="https://github.com/own-pay/ownpay">GitHub</a>
                    <a href="https://ownpay.org">Built by the Community, for the Community</a>
                </div>
            </div>
        </div>

        <div class="op-mobile-brand-footer">
            <div class="op-mobile-brand-logo">
                <img src="/assets/img/logo-dark.svg" alt="{{ app_name ?? 'OwnPay' }}" style="height: 24px; width: auto;">
            </div>
            <div class="op-mobile-brand-text">
                <span class="op-mobile-brand-static">OwnPay</span>
                <div class="op-rotating-wrapper op-mobile-rotating-wrapper" id="op-mobile-rotating-wrapper">
                    <div class="op-word-track op-mobile-word-track" id="op-mobile-word-track"></div>
                </div>
            </div>
            <p class="op-mobile-brand-tagline">The payment gateway that puts you in control.</p>
            <div class="op-mobile-brand-links">
                <a href="#">Privacy Policy</a>
                <a href="#">Terms of Service</a>
                <a href="#">Contact</a>
            </div>
        </div>
    </div>

    <script nonce="{{ csp_nonce }}">
    (function() {
        let isTypingPassword = false;
        let isTypingEmail = false;
        let showPassword = false;
        let mouseX = window.innerWidth / 2;
        let mouseY = window.innerHeight / 2;

        const chars = {
            purple: { body: document.getElementById('char-purple'), eyes: document.querySelectorAll('#eyes-purple .op-eye-base'), pupils: document.querySelectorAll('#eyes-purple .op-pupil'), maxDist: 8 },
            black: { body: document.getElementById('char-black'), eyes: document.querySelectorAll('#eyes-black .op-eye-base'), pupils: document.querySelectorAll('#eyes-black .op-pupil'), maxDist: 6 },
            orange: { body: document.getElementById('char-orange'), pupils: document.querySelectorAll('#eyes-orange .op-pupil'), maxDist: 6 },
            yellow: { body: document.getElementById('char-yellow'), pupils: document.querySelectorAll('#eyes-yellow .op-pupil'), maxDist: 6 }
        };

        const emailInput = document.getElementById('email');
        const passwordInput = document.getElementById('password');
        const toggleBtn = document.getElementById('togglePassword');
        const eyeIcon = document.getElementById('eye-icon');
        const speechBubble = document.getElementById('speech-bubble');

        toggleBtn.addEventListener('click', function() {
            showPassword = !showPassword;
            passwordInput.type = showPassword ? 'text' : 'password';

            if (showPassword) {
                eyeIcon.innerHTML = '<path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/><path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/><path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/><line x1="2" x2="22" y1="2" y2="22"/>';
            } else {
                eyeIcon.innerHTML = '<path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/>';
            }
            updateCharacters();
        });

        passwordInput.addEventListener('focus', function() { isTypingPassword = true; updateCharacters(); });
        passwordInput.addEventListener('blur', function() { isTypingPassword = false; updateCharacters(); });

        emailInput.addEventListener('focus', function() { isTypingEmail = true; updateCharacters(); });
        emailInput.addEventListener('blur', function() { isTypingEmail = false; updateCharacters(); });

        function handlePointerMove(e) {
            if (e.touches && e.touches.length > 0) {
                mouseX = e.touches[0].clientX;
                mouseY = e.touches[0].clientY;
            } else {
                mouseX = e.clientX;
                mouseY = e.clientY;
            }
            if (!isTypingPassword && !isTypingEmail) updateCharacters();
        }

        window.addEventListener('mousemove', handlePointerMove);
        window.addEventListener('touchmove', handlePointerMove, { passive: true });
        window.addEventListener('touchstart', handlePointerMove, { passive: true });

        function updateCharacters() {
            var centerWindow = window.innerWidth / 2;
            var deltaX = mouseX - centerWindow;
            var baseSkew = Math.max(-6, Math.min(6, -deltaX / 120));

            Object.keys(chars).forEach(function(key) {
                var char = chars[key];
                var rect = char.body.getBoundingClientRect();

                var eyeCenterX = rect.left + rect.width / 2;
                var eyeCenterY = rect.top + rect.height / 3;
                var dx = mouseX - eyeCenterX;
                var dy = mouseY - eyeCenterY;
                var angle = Math.atan2(dy, dx);
                var dist = Math.min(Math.hypot(dx, dy) / 30, char.maxDist);

                var targetPupilX = Math.cos(angle) * dist;
                var targetPupilY = Math.sin(angle) * dist;

                if (isTypingPassword && !showPassword) {
                    speechBubble.classList.add('visible');

                    if (key === 'purple') char.body.style.transform = 'skewX(' + (baseSkew - 8) + 'deg) translateX(20px)';
                    if (key === 'black') char.body.style.transform = 'skewX(' + (baseSkew * 1.5 + 5) + 'deg) translateX(10px)';

                    if (char.eyes) {
                        char.eyes.forEach(function(eye) {
                            eye.style.height = '4px';
                            eye.style.borderRadius = '2px';
                            eye.style.backgroundColor = '#000';
                        });
                    }
                    char.pupils.forEach(function(pupil) { pupil.style.opacity = '0'; });

                } else if (isTypingPassword && showPassword) {
                    speechBubble.classList.remove('visible');
                    char.body.style.transform = 'skewX(0deg)';

                    if (char.eyes) {
                        char.eyes.forEach(function(eye) {
                            eye.style.height = key === 'purple' ? '36px' : '32px';
                            eye.style.borderRadius = '50% / 60%';
                            eye.style.backgroundColor = 'white';
                        });
                    }
                    char.pupils.forEach(function(pupil) { pupil.style.opacity = '1'; });

                    if (window.innerWidth < 1024) {
                        targetPupilX = 0; targetPupilY = char.maxDist;
                    } else {
                        targetPupilX = char.maxDist; targetPupilY = 0;
                    }

                } else {
                    speechBubble.classList.remove('visible');
                    char.body.style.transform = 'skewX(' + (key === 'black' ? baseSkew * 1.5 : baseSkew) + 'deg)';

                    if (char.eyes) {
                        char.eyes.forEach(function(eye) {
                            eye.style.height = key === 'purple' ? '36px' : '32px';
                            eye.style.borderRadius = '50% / 60%';
                            eye.style.backgroundColor = 'white';
                        });
                    }
                    char.pupils.forEach(function(pupil) { pupil.style.opacity = '1'; });

                    if (isTypingEmail && window.innerWidth < 1024) {
                        targetPupilX = 0;
                        targetPupilY = char.maxDist;
                    }
                }

                char.pupils.forEach(function(pupil) {
                    pupil.style.transform = 'translate(' + targetPupilX + 'px, ' + targetPupilY + 'px)';
                });
            });
        }

        function triggerBlink(charKey) {
            if (isTypingPassword && !showPassword) return;

            var char = chars[charKey];
            char.eyes.forEach(function(eye) {
                eye.style.height = '2px';
                eye.style.borderRadius = '2px';
            });

            setTimeout(function() {
                if (!isTypingPassword || showPassword) {
                    char.eyes.forEach(function(eye) {
                        eye.style.height = charKey === 'purple' ? '36px' : '32px';
                        eye.style.borderRadius = '50% / 60%';
                    });
                }
            }, 150);
        }

        setInterval(function() { triggerBlink('purple'); }, 4000);
        setInterval(function() { triggerBlink('black'); }, 5500);
        updateCharacters();

        /* -- Texts Reveal: stagger header entrance -- */
        var headerStagger = document.getElementById('header-stagger');
        if (headerStagger) {
            headerStagger.classList.remove('is-hiding');
            headerStagger.classList.remove('is-shown');
            void headerStagger.offsetHeight;
            headerStagger.classList.add('is-shown');
        }

        /* -- Error State Shake -- */
        var errorWrap = document.getElementById('error-wrap');
        var errorAlert = errorWrap ? errorWrap.querySelector('.op-alert') : null;
        if (errorAlert) {
            errorWrap.classList.add('is-error');
            errorAlert.classList.add('t-input', 'is-error');

            errorAlert.classList.remove('is-shaking');
            void errorAlert.offsetWidth;
            errorAlert.classList.add('is-shaking');

            var cs = getComputedStyle(document.documentElement);
            var shakeMs =
                (parseFloat(cs.getPropertyValue('--shake-dur-a')) || 80) * 2 +
                (parseFloat(cs.getPropertyValue('--shake-dur-b')) || 60) * 2;
            setTimeout(function() { errorAlert.classList.remove('is-shaking'); }, shakeMs + 20);

            var hold = parseFloat(cs.getPropertyValue('--revert-hold')) || 3000;
            setTimeout(function() {
                errorWrap.classList.remove('is-error');
                errorAlert.classList.remove('is-error');
            }, shakeMs + hold);
        }

        /* -- Hero Text Rotation -- */
        var heroTexts = [
            "your money, stays yours.",
            "your gateway, your rules.",
            "secure by design.",
            "built for scale.",
            "payments, simplified.",
            "no middlemen.",
            "fast. secure. yours."
        ];

        var wordTrack = document.getElementById('op-word-track');
        var mobileWordTrack = document.getElementById('op-mobile-word-track');
        var heroIndex = 0;
        var staggerDuration = 0.025;
        var rotationInterval = 2500;

        function buildWordElements(track, word) {
            track.innerHTML = '';
            var chars = Array.from(word);
            chars.forEach(function(char, index) {
                var span = document.createElement('span');
                if (char === ' ') {
                    span.innerHTML = '&nbsp;';
                } else {
                    span.textContent = char;
                }
                span.className = 'op-char';
                var delay = (chars.length - 1 - index) * staggerDuration;
                span.style.animationDelay = delay + 's';
                track.appendChild(span);
            });
        }

        function cycleTrack(track) {
            var currentWord = heroTexts[heroIndex];
            buildWordElements(track, currentWord);
            track.classList.remove('op-animating-out');
            track.classList.add('op-animating-in');

            var charsLength = Array.from(currentWord).length;
            var maxDelay = (charsLength - 1) * staggerDuration * 1000;

            setTimeout(function() {
                track.classList.remove('op-animating-in');
                track.classList.add('op-animating-out');
            }, rotationInterval - 400);
        }

        function cycleHeroText() {
            var tracks = [];
            if (wordTrack) tracks.push(wordTrack);
            if (mobileWordTrack) tracks.push(mobileWordTrack);

            tracks.forEach(function(track) { cycleTrack(track); });

            var currentWord = heroTexts[heroIndex];
            var charsLength = Array.from(currentWord).length;
            var maxDelay = (charsLength - 1) * staggerDuration * 1000;

            setTimeout(function() {
                heroIndex = (heroIndex + 1) % heroTexts.length;
                cycleHeroText();
            }, rotationInterval + maxDelay);
        }

        if (wordTrack || mobileWordTrack) {
            cycleHeroText();
        }
    })();
    </script>
</body>
</html>
