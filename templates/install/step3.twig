<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><meta name="robots" content="noindex,nofollow"><title>Admin Account · Own Pay Setup</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/css/installer.css">
</head><body>
<header class="ins-header"><div class="ins-brand"><span class="ins-mark">OP</span><span class="ins-name">Own Pay <span>Setup</span></span></div><span class="ins-badge">Step 3/4</span></header>
<main class="ins-main"><div class="ins-card">
<h1>Create Admin Account</h1>
<p class="ins-sub">This will be your super admin login.</p>
<form id="adminForm" class="ins-form">
    <div class="ins-field"><label>Full Name</label><input name="name" required placeholder="John Doe"></div>
    <div class="ins-field"><label>Email</label><input name="email" type="email" required placeholder="admin@example.com"></div>
    <div class="ins-field"><label>Username</label><input name="username" required placeholder="admin"></div>
    <div class="ins-field"><label>Password</label><input name="password" type="password" required minlength="8" placeholder="Min 8 characters"></div>
    <div id="adminMsg" class="ins-msg"></div>
    <button type="submit" class="ins-btn" id="adminBtn">Create Admin</button>
</form>
</div></main>
<script>
document.getElementById('adminForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    var btn = document.getElementById('adminBtn'), msg = document.getElementById('adminMsg');
    btn.disabled = true; btn.textContent = 'Creating...'; msg.textContent = '';
    var fd = new FormData(this), body = {};
    fd.forEach(function(v,k){ body[k] = v; });
    try {
        var r = await fetch('/install/create-admin', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(body)});
        var d = await r.json();
        if (d.success) { msg.className = 'ins-msg ins-msg-ok'; msg.textContent = '✓ Admin created'; setTimeout(function(){ location.href='?step=4'; }, 800); }
        else { msg.className = 'ins-msg ins-msg-err'; msg.textContent = '✗ ' + (d.error||'Failed'); btn.disabled = false; btn.textContent = 'Create Admin'; }
    } catch(err) { msg.className = 'ins-msg ins-msg-err'; msg.textContent = '✗ Network error'; btn.disabled = false; btn.textContent = 'Create Admin'; }
});
</script>
</body></html>
